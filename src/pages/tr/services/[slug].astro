---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.lang === 'tr');
  return services.map(s => ({
    params: { slug: s.id.split('/').pop().replace('.md', '') },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;
const rendered = await render(entry);
const { Content } = rendered;
const headings = rendered.headings || [];
---

<Layout title={`${entry.data.title} | Luvi Bilişim`} lang="tr">
  <main class="bg-white min-h-screen relative">
    
    <!-- Hero Header with Brand Color Accent -->
    <div class="pt-40 pb-24 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#154360 1px, transparent 1px); background-size: 30px 30px;"></div>
        <div class="container mx-auto px-4 md:px-8 relative z-10">
             <!-- Breadcrumbs -->
             <div class="flex items-center gap-4 mb-12">
                <a href="/tr" class="text-slate-400 hover:text-[#5dade2] font-sans font-black text-[10px] tracking-[0.3em] uppercase transition-colors">ANA SAYFA</a>
                <div class="w-1 h-1 rounded-full bg-slate-300"></div>
                <a href="/tr#services" class="text-slate-400 hover:text-[#5dade2] font-sans font-black text-[10px] tracking-[0.3em] uppercase transition-colors">HİZMETLER</a>
                <div class="w-1 h-1 rounded-full bg-slate-300"></div>
                <span class="text-[#5dade2] font-sans font-black text-[10px] tracking-[0.3em] uppercase">{entry.data.category}</span>
             </div>

             <h1 class="text-5xl md:text-8xl font-sans font-black text-[#154360] tracking-tighter leading-[0.95] mb-8 max-w-5xl">
                {entry.data.title}
             </h1>
             <div class="h-2 w-32 bg-[#e74c3c] rounded-full"></div>
        </div>
    </div>

    <div class="container mx-auto px-4 md:px-8 py-20">
      <div class="flex flex-col lg:flex-row gap-24">
        
        <!-- Sidebar: Elite Navigation -->
        <aside class="lg:w-1/4">
          <div class="sticky top-40">
            <div class="mb-12">
                <h4 class="text-[#154360] font-sans font-black text-xs tracking-[0.5em] uppercase mb-8 flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-[#e74c3c]"></div>
                    BÖLÜMLER
                </h4>
                <nav id="sections-nav" class="flex flex-col gap-2 border-l border-slate-100">
                  {/* Dynamic Headings will be injected here by script if SSR fails */}
                  {headings.length > 0 && headings.filter(h => h.depth >= 2 && h.depth <= 3).map(h => (
                    <a 
                      href={`#${h.slug}`} 
                      class={`pl-6 py-3 text-sm font-sans font-bold tracking-tight transition-all duration-300 hover:text-[#154360] border-l-2 border-transparent hover:border-[#5dade2] -ml-[1px]
                        ${h.depth === 3 ? 'text-slate-400 font-bold' : 'text-[#154360] font-black uppercase text-xs tracking-widest mt-4'}
                      `}
                    >
                      {h.text}
                    </a>
                  ))}
                </nav>
            </div>

            <!-- Pro Card -->
            <div class="p-10 rounded-[40px] bg-[#154360] text-white relative overflow-hidden group">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-white/5 rounded-full blur-3xl"></div>
                <h5 class="text-xl font-sans font-black mb-4 relative z-10 leading-tight">Profesyonel <br/> Analiz İsteyin</h5>
                <p class="text-white/40 text-xs mb-8 relative z-10 leading-relaxed font-medium">Stratejik yol haritanızı uzman ekibimizle birlikte planlayalım.</p>
                <a href="/tr#contact-form" class="relative z-10 inline-flex items-center justify-center w-full bg-[#5dade2] text-[#154360] py-4 rounded-full font-heading font-black text-xs hover:bg-white transition-all shadow-xl">
                  TEKLİF ALIN
                </a>
            </div>
          </div>
        </aside>

        <!-- Main Content: Authority Layout -->
        <article id="service-content" class="lg:w-3/4">
          <div class="max-w-4xl">
            <!-- Strategic Summary -->
            <div class="mb-24 p-12 bg-slate-50 rounded-[40px] border border-slate-100 italic">
                <p class="text-slate-600 text-xl font-medium leading-relaxed">
                   "{entry.data.description}"
                </p>
            </div>

            <!-- Content Rendering -->
            <div class="prose prose-slate prose-xl max-w-none 
              prose-headings:font-sans prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-[#154360]
              prose-h3:text-4xl prose-h3:mt-32 prose-h3:mb-12 prose-h3:pt-32 prose-h3:border-t prose-h3:border-slate-50
              prose-p:text-slate-500 prose-p:leading-relaxed prose-p:font-medium prose-p:text-lg
              prose-li:text-slate-500 prose-li:font-medium prose-strong:text-[#154360]
            ">
              <Content />
            </div>

            <!-- Footer CTA -->
            <div class="mt-40 p-16 rounded-[48px] bg-slate-900 border border-slate-800 flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-2xl bg-[#e74c3c]/20 flex items-center justify-center text-[#e74c3c] mb-8">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <h3 class="text-3xl md:text-5xl font-sans font-black text-white mb-6 tracking-tighter">Dijital Geleceğinizi <br/> <span class="text-[#5dade2]">Bugünden</span> Kurgulayın</h3>
                <p class="text-slate-500 text-lg mb-12 max-w-2xl font-medium">Bütünsel teknoloji yönetimi ve siber güvenlik stratejileri ile kurumunuzun rekabet avantajını koruyoruz.</p>
                <a href="/tr/#contact-form" class="bg-white text-[#154360] px-14 py-6 rounded-full font-heading font-black text-lg hover:bg-[#5dade2] transition-all shadow-2xl hover:-translate-y-2">
                    Bize Ulaşın
                </a>
            </div>
          </div>
        </article>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  function populateSections() {
    const nav = document.getElementById('sections-nav');
    const content = document.getElementById('service-content');
    if (!nav || !content) return;

    // If SSR already populated, do nothing unless it's empty
    if (nav.children.length > 0) return;

    const headings = content.querySelectorAll('h1, h2, h3, h4');
    console.log('[Sidebar Debug] Headings found in DOM:', headings.length);
    
    headings.forEach((h, index) => {
      if (!h.id) {
        h.id = 'section-' + index;
      }
      console.log(`[Sidebar Debug] Adding: ${h.textContent} (${h.tagName}) -> #${h.id}`);

      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      
      // Base styles
      a.className = 'pl-6 py-3 text-sm font-sans font-bold tracking-tight transition-all duration-300 hover:text-[#154360] border-l-2 border-transparent hover:border-[#5dade2] -ml-[1px]';
      
      // Depth specific styles
      if (h.tagName === 'H3') {
        a.classList.add('text-slate-400');
      } else {
        a.classList.add('text-[#154360]', 'font-black', 'uppercase', 'text-xs', 'tracking-widest', 'mt-4');
      }

      nav.appendChild(a);
    });
  }

  // Run on load
  window.addEventListener('DOMContentLoaded', populateSections);
  // Also run immediately in case DOM is already ready
  populateSections();
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
