---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allServices = await getCollection('services');
  
  // Debug output if we could see it:
  // console.log("SERVICES IDs:", allServices.map(s => s.id));

  return allServices.map((entry) => {
    // Robust slug: ai-automation/tr -> ai-automation
    const idParts = entry.id.split('/');
    const slug = idParts.length > 1 ? idParts[0] : entry.id.replace('.md', '').replace(/\/(tr|en)$/, '');
    
    return {
      params: { 
        lang: entry.data.lang, 
        id: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const allServices = await getCollection('services');

// Filter out the current service and only show same-language services
const currentId = entry.id;
const otherServices = allServices
  .filter((s: any) => s.id !== currentId && s.data.lang === entry.data.lang)
  .sort((a: any, b: any) => (a.data.order || 99) - (b.data.order || 99));

const { Content } = await render(entry);
---

<ContentDetailLayout frontmatter={entry.data} otherServices={otherServices}>
  <Content />
</ContentDetailLayout>
