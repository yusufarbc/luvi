---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map((entry) => ({
    params: { 
      lang: entry.data.lang, 
      id: entry.id.split('/').pop()?.replace('.md', '') 
    },
    props: { entry, allProducts },
  }));
}

const { entry, allProducts } = Astro.props;
const { Content } = await render(entry);

// Filter out the current product and only show same-language products
const currentId = entry.id;
const otherProducts = allProducts
  .filter((p: any) => p.id !== currentId && p.data.lang === entry.data.lang)
  .sort((a: any, b: any) => (a.data.order || 99) - (b.data.order || 99));
---

<ContentDetailLayout frontmatter={entry.data} otherProducts={otherProducts}>
  <Content />
</ContentDetailLayout>
