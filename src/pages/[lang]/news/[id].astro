---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map((entry) => {
    const slug = entry.id.includes('/') ? entry.id.split('/')[0] : entry.id.replace('.md', '');
    return {
      params: { 
        lang: entry.data.lang, 
        id: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Filter out the main cover image from the gallery to avoid duplication
const gallery = entry.data.gallery || [];
const coverImage = entry.data.image;

const filteredGallery = gallery
  .filter((item: any) => {
    // Each item is { src: Metadata, alt: string }
    const img = item.src;
    const imgPath = typeof img === 'string' ? img : (img?.src || img);
    const coverPath = typeof coverImage === 'string' ? coverImage : (coverImage?.src || coverImage);
    
    const getFn = (p: any) => {
      const s = typeof p === 'string' ? p : p?.src;
      return s?.split('/').pop()?.split('.')[0] || '';
    };
    
    return getFn(imgPath) !== getFn(coverPath);
  })
  .map((item: any) => item.src);
---

<ContentDetailLayout 
  frontmatter={entry.data} 
  showContactCTA={false}
  galleryImages={filteredGallery}
>
  <div class="prose prose-slate prose-lg max-w-none prose-headings:text-[#154360] prose-p:text-slate-500">
    <Content />
  </div>
</ContentDetailLayout>
