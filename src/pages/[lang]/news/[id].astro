---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allNews = await getCollection('news');
  return allNews.map((entry) => {
    const slug = entry.id.includes('/') ? entry.id.split('/')[0] : entry.id.replace('.md', '');
    return {
      params: { 
        lang: entry.data.lang, 
        id: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Dynamic Gallery Discovery using relative paths
// We need to resolve these images for Astro to process them
const gallery = entry.data.gallery || [];
const resolvedGallery = await Promise.all(
  gallery.map(async (img: any) => {
    // Attempt to resolve the image from the same directory
    // In Astro 5 content collections with glob loader, the image already comes as an object if it's in the schema as image()
    // However, for gallery arrays we might need a different trick
    return img;
  })
);
---

<ContentDetailLayout 
  frontmatter={entry.data} 
  showContactCTA={false}
  galleryImages={resolvedGallery}
>
  <div class="prose prose-slate prose-lg max-w-none prose-headings:text-[#154360] prose-p:text-slate-500">
    <Content />
  </div>
</ContentDetailLayout>
