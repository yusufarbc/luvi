---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map((entry) => {
    // Handling folder-based slugs: marmara-uni/index.md -> marmara-uni
    const slug = entry.id.includes('/') ? entry.id.split('/')[0] : entry.id.replace('.md', '');
    return {
      params: { 
        lang: entry.data.lang, 
        id: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentDetailLayout frontmatter={entry.data}>
  <div class="prose prose-invert max-w-none">
    <Content />
  </div>
</ContentDetailLayout>
