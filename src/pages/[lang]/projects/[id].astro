---
import { getCollection, render } from 'astro:content';
import ContentDetailLayout from '../../../layouts/ContentDetailLayout.astro';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map((entry) => {
    const slug = entry.slug || (() => {
      let id = (entry.id || '').toString();
      if (id.endsWith('.md')) id = id.replace(/\.md$/, '');
      const parts = id.split('/').filter(Boolean);
      let s = parts.length ? parts[parts.length - 1] : '';
      if (s === 'tr' || s === 'en') s = parts.length >= 2 ? parts[parts.length - 2] : s;
      return s;
    })();
    return {
      params: { 
        lang: entry.data.lang, 
        id: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ContentDetailLayout frontmatter={entry.data}>
  <div class="prose prose-invert max-w-none">
    <Content />
  </div>
</ContentDetailLayout>
