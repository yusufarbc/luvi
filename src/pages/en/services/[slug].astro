---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.lang === 'en');
  return services.map(s => {
    const normalizedId = s.id.replace(/\\/g, '/');
    const slug = normalizedId.includes('/') ? normalizedId.split('/')[0] : normalizedId.replace('.md', '');
    return {
      params: { slug },
      props: { entry: s, allServices: services },
    };
  });
}

const { entry, allServices } = Astro.props;
const rendered = await render(entry);
const { Content } = rendered;
const headings = rendered.headings || [];

const currentNormalizedId = entry.id.replace(/\\/g, '/');
const currentSlug = currentNormalizedId.includes('/') ? currentNormalizedId.split('/')[0] : currentNormalizedId.replace('.md', '');

const otherServices = allServices
  .filter(s => {
    const sNormalizedId = s.id.replace(/\\/g, '/');
    const sSlug = sNormalizedId.includes('/') ? sNormalizedId.split('/')[0] : sNormalizedId.replace('.md', '');
    return sSlug !== currentSlug;
  })
  .sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`${entry.data.title} | Luvi Bilişim`} lang="en">
  <main class="bg-white min-h-screen relative">
    
    <!-- Header Strategy -->
    <div class="pt-32 pb-20 bg-gradient-to-b from-slate-50 to-white relative overflow-hidden">
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#154360 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="container mx-auto px-4 md:px-8 relative z-10">
             <!-- Breadcrumbs -->
             <nav class="flex items-center gap-4 mb-16 px-1">
                <a href={`${base}/en`} class="text-slate-400 hover:text-[#5dade2] font-sans font-black text-[10px] tracking-[0.4em] uppercase transition-all">HOME</a>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dade2]/30"></div>
                <a href={`${base}/en#services`} class="text-slate-400 hover:text-[#5dade2] font-sans font-black text-[10px] tracking-[0.4em] uppercase transition-all">SERVICES</a>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dade2]/30"></div>
                <span class="text-[#154360] font-sans font-black text-[10px] tracking-[0.4em] uppercase opacity-40">{entry.data.category}</span>
             </nav>

             <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-12 max-w-7xl mx-auto">
                <div class="max-w-4xl">
                    <h1 class="text-5xl md:text-7xl lg:text-8xl font-sans font-black text-[#154360] tracking-tighter leading-[0.9] mb-10">
                        {entry.data.title}
                    </h1>
                    <div class="h-2 w-32 bg-[#5dade2] rounded-full"></div>
                </div>
                <div class="lg:w-1/3 pb-2">
                    <p class="text-slate-400 text-lg md:text-xl font-sans leading-relaxed font-light">
                        {entry.data.description}
                    </p>
                </div>
             </div>
        </div>
    </div>

    <div class="container mx-auto px-4 md:px-8 py-24 max-w-7xl">
      <div class="flex flex-col lg:flex-row gap-20">
        
        <!-- Sidebar Navigation -->
        <aside class="lg:w-1/4">
          <div class="sticky top-40 space-y-12">
            <div>
                <h4 class="text-[#154360] font-sans font-black text-[11px] tracking-[0.5em] uppercase mb-10 flex items-center gap-3 opacity-40">
                    SECTIONS
                </h4>
                <nav id="sections-nav" class="flex flex-col gap-1 border-l-2 border-slate-50 ml-1">
                  {headings.length > 0 && headings.filter(h => h.depth >= 2 && h.depth <= 3).map(h => (
                    <a 
                      href={`#${h.slug}`} 
                      class={`pl-6 py-3 text-sm font-sans font-bold tracking-tight transition-all duration-300 hover:text-[#154360] border-l-2 border-transparent hover:border-[#5dade2] -ml-[2px]
                        ${h.depth === 3 ? 'text-slate-400' : 'text-[#154360] font-black uppercase text-[11px] tracking-widest mt-4 first:mt-0'}
                      `}
                    >
                      {h.text}
                    </a>
                  ))}
                </nav>
            </div>

            <!-- Premium Dynamic CTA -->
            <div class="relative p-8 md:p-10 rounded-[48px] bg-[#154360] text-white overflow-hidden group shadow-2xl">
                <div class="absolute -right-16 -top-16 w-64 h-64 bg-[#5dade2]/10 rounded-full blur-3xl transition-transform duration-1000 group-hover:scale-150"></div>
                <div class="absolute -left-16 -bottom-16 w-48 h-48 bg-[#5dade2]/5 rounded-full blur-3xl transition-transform duration-1000 group-hover:scale-150"></div>
                
                <div class="relative z-10">
                    <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center text-[#5dade2] mb-8 group-hover:scale-110 transition-transform duration-500 border border-white/5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    </div>
                    <h5 class="text-2xl md:text-3xl font-sans font-black mb-4 leading-[1.1] tracking-tight">
                        Design Your <br/> <span class="text-[#5dade2]">Digital</span> Future Today
                    </h5>
                    <p class="text-white/50 text-sm mb-10 leading-relaxed font-medium">
                        We strengthen your organization's digital reflexes with strategic technology management. 
                    </p>
                    <a href={`${base}/en#contact-form`} class="inline-flex items-center justify-center w-full bg-white text-[#154360] py-5 rounded-full font-heading font-black text-xs hover:bg-[#5dade2] hover:text-[#154360] transition-all shadow-xl hover:-translate-y-1 gap-3 group/btn">
                        CONTACT US
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </a>
                </div>
            </div>
          </div>
        </aside>

        <!-- Main Content Area -->
        <article id="service-content" class="lg:w-3/4">
          <div class="max-w-4xl">
            {entry.data.image && (
              <div class="mb-24 rounded-[64px] overflow-hidden bg-slate-50 aspect-[16/9] shadow-[0_40px_100px_-20px_rgba(21,67,96,0.15)] border border-slate-100 ring-1 ring-black/5">
                <img 
                  src={entry.data.image.src || entry.data.image} 
                  alt={entry.data.title} 
                  class="w-full h-full object-cover"
                />
              </div>
            )}

            <div class="prose prose-slate prose-xl max-w-none 
              prose-headings:font-sans prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-[#154360]
              prose-h2:text-3xl md:prose-h2:text-5xl prose-h2:mt-32 prose-h2:mb-16 prose-h2:border-l-[12px] prose-h2:border-[#5dade2] prose-h2:pl-10 prose-h2:relative prose-h2:leading-[1.1]
              prose-h3:text-xl md:prose-h3:text-2xl prose-h3:mt-24 prose-h3:mb-10 prose-h3:font-extrabold prose-h3:text-[#154360]/90 prose-h3:border-l-4 prose-h3:border-slate-200 prose-h3:pl-8
              prose-p:text-slate-600 prose-p:leading-[1.9] prose-p:font-normal prose-p:text-lg md:prose-p:text-xl prose-p:mb-10 prose-p:text-justify
              prose-li:text-slate-600 prose-li:font-normal prose-li:text-lg md:prose-li:text-xl prose-li:mb-5
              prose-strong:text-[#154360] prose-strong:font-bold
              prose-blockquote:border-l-[10px] prose-blockquote:border-[#5dade2] prose-blockquote:pl-12 prose-blockquote:italic prose-blockquote:text-2xl prose-blockquote:text-[#154360] prose-blockquote:bg-slate-50 prose-blockquote:py-16 prose-blockquote:pr-10 prose-blockquote:rounded-r-[40px] prose-blockquote:my-24 prose-blockquote:shadow-sm
            ">
              <Content />
            </div>
          </div>
        </article>
      </div>

      {otherServices.length > 0 && (
        <div class="mt-40 pt-24 border-t border-slate-100">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-8">
                <div class="max-w-2xl">
                    <span class="inline-flex items-center gap-3 text-[#5dade2] font-sans font-black text-[10px] tracking-[0.4em] uppercase mb-6">
                        <div class="w-8 h-px bg-[#5dade2]/30"></div>
                        CONTINUE EXPLORING
                    </span>
                    <h2 class="text-[#154360] font-sans font-black text-3xl md:text-5xl tracking-tighter">
                        Other Services
                    </h2>
                </div>
                <a href={`${base}/en#services`} class="text-[#154360]/40 hover:text-[#5dade2] font-sans font-black text-[10px] tracking-[0.3em] uppercase transition-all flex items-center gap-3 group">
                    VIEW ALL
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                {otherServices.slice(0, 3).map((service) => (
                  <a 
                    href={`${base}/en/services/${service.id.replace(/\\/g, '/').includes('/') ? service.id.replace(/\\/g, '/').split('/')[0] : service.id.replace(/\\/g, '/').replace('.md', '')}`}
                    class="group relative flex flex-col bg-white border border-slate-100 p-8 rounded-[40px] transition-all duration-1000 hover:border-[#5dade2]/30 hover:shadow-[0_40px_80px_-20px_rgba(21,67,160,0.1)]"
                  >
                    <div class="relative w-full aspect-[16/10] mb-8 rounded-[24px] overflow-hidden bg-slate-50 transition-all duration-1000 group-hover:scale-[1.03]">
                      <img 
                        src={service.data.category === 'security' ? '/services/security.png' : service.data.category === 'strategy' ? '/services/strategy.png' : service.data.category === 'compliance' ? '/services/compliance.png' : '/services/ai.png'} 
                        alt={service.data.title}
                        class="w-full h-full object-cover transform transition-transform duration-[2000ms] group-hover:scale-110"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-[#154360]/20 to-transparent"></div>
                    </div>
                    
                    <h4 class="text-[#154360] font-sans font-black text-xl mb-4 tracking-tight group-hover:text-[#5dade2] transition-colors duration-500 uppercase leading-tight">
                      {service.data.title}
                    </h4>
                    <p class="text-slate-400 text-sm leading-relaxed mb-8 line-clamp-2">
                      {service.data.description}
                    </p>
                    
                    <div class="mt-auto pt-6 flex items-center justify-between border-t border-slate-50">
                      <span class="text-[9px] font-sans font-black tracking-[0.3em] uppercase text-[#154360]/40 group-hover:text-[#5dade2] transition-colors duration-500">
                        DETAILED ANALYSIS
                      </span>
                      <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-[#154360] group-hover:bg-[#154360] group-hover:text-white transition-all duration-500 group-hover:translate-x-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                      </div>
                    </div>
                  </a>
                ))}
            </div>
        </div>
      )}
    </div>
  </main>
</Layout>

<script is:inline>
  function populateSections() {
    const nav = document.getElementById('sections-nav');
    const content = document.getElementById('service-content');
    if (!nav || !content) return;

    if (nav.children.length > 0) return;

    const headings = content.querySelectorAll('h2, h3');
    headings.forEach((h, index) => {
      if (!h.id) {
        h.id = 'section-' + index;
      }
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent;
      a.className = 'pl-6 py-3 text-sm font-sans font-bold tracking-tight transition-all duration-300 hover:text-[#154360] border-l-2 border-transparent hover:border-[#5dade2] -ml-[2px]';
      
      if (h.tagName === 'H3') {
        a.classList.add('text-slate-400');
      } else {
        a.classList.add('text-[#154360]', 'font-black', 'uppercase', 'text-[11px]', 'tracking-widest', 'mt-4', 'first:mt-0');
      }
      nav.appendChild(a);
    });
  }
  window.addEventListener('DOMContentLoaded', populateSections);
  populateSections();
</script>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
