---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.lang === 'en');
  return services.map(s => ({
    params: { slug: s.id.split('/').pop().replace('.md', '') },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;
const rendered = await entry.render();
const { Content, headings } = rendered;
---

<Layout title={`${entry.data.title} | Luvi IT`} lang="en">
  <main class="pt-32 pb-40 min-h-screen bg-white">
    <div class="container mx-auto px-4 md:px-8">
      <!-- Breadcrumb / Back -->
      <a href="/en" class="inline-flex items-center gap-4 text-[#5dade2] font-sans font-black text-xs tracking-[0.4em] uppercase mb-16 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:-translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" /></svg>
          HOME
      </a>

      <div class="flex flex-col lg:flex-row gap-20">
        <!-- Sidebar Navigation -->
        <aside class="lg:w-1/4">
          <div class="sticky top-40">
            <h4 class="text-[#154360]/30 font-sans font-black text-[10px] tracking-[0.5em] uppercase mb-10 border-b border-slate-100 pb-4">
              SECTIONS
            </h4>
            <nav class="flex flex-col gap-4">
              {headings.filter(h => h.depth === 3).map(h => (
                <a 
                  href={`#${h.slug}`} 
                  class="text-slate-400 hover:text-[#5dade2] font-sans font-bold text-sm tracking-tight transition-all duration-300 hover:translate-x-2 flex items-center gap-3 group"
                >
                  <div class="w-1.5 h-1.5 rounded-full bg-[#5dade2] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                  {h.text}
                </a>
              ))}
            </nav>

            <div class="mt-20 p-8 rounded-[32px] bg-slate-50 border border-slate-100">
                <h5 class="text-[#154360] font-black text-lg mb-4">Quick Contact</h5>
                <p class="text-slate-500 text-sm mb-6 leading-relaxed">Reach out to our expert team for more information on these service details.</p>
                <a href="/en#contact-form" class="inline-block bg-[#154360] text-white px-8 py-4 rounded-full font-heading font-black text-xs hover:bg-[#5dade2] transition-all shadow-lg text-center w-full">
                  GET A QUOTE
                </a>
            </div>
          </div>
        </aside>

        <!-- Main Content Area -->
        <article class="lg:w-3/4">
          <div class="max-w-5xl">
            <h1 class="text-5xl md:text-8xl font-sans font-black text-[#154360] mb-12 leading-[1.05] tracking-tighter">
              {entry.data.title}
            </h1>
            
            <div class="h-2 w-24 bg-[#e74c3c] rounded-full mb-16"></div>

            <div class="prose prose-slate prose-xl max-w-none 
              prose-headings:font-sans prose-headings:font-black prose-headings:tracking-tighter prose-headings:text-[#154360]
              prose-h3:text-4xl prose-h3:mt-24 prose-h3:mb-10 prose-h3:pt-24 prose-h3:border-t prose-h3:border-slate-50
              prose-p:text-slate-500 prose-p:leading-relaxed prose-p:font-medium prose-p:text-lg
              prose-li:text-slate-500 prose-li:font-medium
            ">
              <Content />
            </div>

            <div class="mt-24 p-12 md:p-16 rounded-[48px] bg-[#154360] text-white relative overflow-hidden group shadow-2xl">
                <div class="absolute -right-20 -top-20 w-80 h-80 bg-white/5 rounded-full blur-3xl transition-transform duration-1000 group-hover:scale-150"></div>
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
                  <div class="max-w-xl">
                    <h3 class="text-3xl md:text-4xl font-sans font-black mb-6 leading-tight">Secure the Future <br/> Together</h3>
                    <p class="text-white/60 text-lg leading-relaxed font-medium">{entry.data.description}</p>
                  </div>
                  <a href="/en/#contact-form" class="shrink-0 bg-[#5dade2] text-[#154360] px-12 py-6 rounded-full font-heading font-black text-lg hover:bg-white transition-all shadow-xl hover:-translate-y-2">
                    Let's Connect
                  </a>
                </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
