---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

import { render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => data.lang === 'en');
  return services.map(s => ({
    params: { slug: s.id.split('/').pop().replace('.md', '') },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | Luvi IT`} lang="en">
  <Header />
  <main class="pt-32 pb-24 min-h-screen bg-slate-50">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-white rounded-[48px] p-12 md:p-20 shadow-sm border border-slate-100">
        <h1 class="text-4xl md:text-6xl font-heading font-black text-[#154360] mb-8 leading-tight tracking-tighter">
          {entry.data.title}
        </h1>
        <div class="about-content prose prose-slate prose-xl max-w-none text-slate-600 leading-relaxed text-justify mb-12">
          <Content />
        </div>
        <div class="prose prose-slate prose-xl max-w-none text-slate-600/60 leading-relaxed text-italic border-l-4 border-[#5dade2]/20 pl-8 mb-16">
          <p class="italic">{entry.data.description}</p>
        </div>
        
        <div class="mt-16 pt-16 border-t border-slate-100 flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <h4 class="text-[#5dade2] font-sans font-black tracking-[0.4em] text-[10px] mb-2">Contact Us</h4>
            <p class="text-[#154360] font-black text-xl">Would you like more information about this service?</p>
          </div>
          <a href="#contact" class="bg-[#154360] text-white px-10 py-5 rounded-full font-heading font-black hover:bg-[#5dade2] transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-1 duration-300">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
