---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-[90vh] w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-white">
  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover opacity-10 transition-opacity duration-1000"
    >
      <source src={`${import.meta.env.BASE_URL}Futuristic_Digital_Network_Animation.webm`} type="video/webm" />
      <source src={`${import.meta.env.BASE_URL}Futuristic_Digital_Network_Animation.mp4`} type="video/mp4" />
    </video>
    <!-- Subtle White Overlay -->
    <div class="absolute inset-0 bg-white/40"></div>
  </div>

  <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
    const video = document.getElementById('hero-video');
    const sources = [
      `${baseUrl}Futuristic_Digital_Network_Animation.webm`,
      `${baseUrl}Cinematic_Tech_Loop_Generation.webm`
    ];
    let currentIndex = 0;

    if (video) {
      video.addEventListener('ended', () => {
        currentIndex = (currentIndex + 1) % sources.length;
        video.style.opacity = '0';
        
        setTimeout(() => {
          video.src = sources[currentIndex];
          video.load();
          video.play();
          video.style.opacity = '0.1';
        }, 500);
      });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <!-- Action Area (Service Cards Only) -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up">
      <ServiceCards isHero={false} />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-20 animate-bounce opacity-20 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-[#154360] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
