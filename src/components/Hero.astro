---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-[80vh] w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-white">
  <!-- Background Layers -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <!-- Subtle Grid Pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(21,67,96,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(21,67,96,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
  </div>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <!-- Corporate Badge -->
    <div class="inline-flex items-center gap-3 px-6 py-2 rounded-full bg-slate-50 border border-slate-100 mb-10 shadow-sm animate-fade-in">
      <span class="w-1.5 h-1.5 bg-[#154360] rounded-full"></span>
      <span class="text-[#154360] text-[10px] font-sans font-bold uppercase tracking-[0.4em]">{t('hero.h2')}</span>
    </div>

    <!-- H1 Headline -->
    <div class="max-w-5xl mx-auto">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-heading font-black text-[#154360] mb-8 leading-[1.1] tracking-tighter">
        {t('hero.h1')}
      </h1>
      <div class="w-24 h-1 bg-[#154360] mx-auto rounded-full mb-12"></div>
    </div>

    <!-- Action Area -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up">
      <ServiceCards />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-20 animate-bounce opacity-20 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-[#154360] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
