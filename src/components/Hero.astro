---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroEntry = await getEntry('hero', lang);
const { title, subtitle } = heroEntry.data;
---

<section class="relative min-h-[95vh] w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-[#0b1a2b]">
  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover opacity-35 transition-opacity duration-1000"
    >
      <source src={`${import.meta.env.BASE_URL}Futuristic_Digital_Network_Animation.webm`} type="video/webm" />
      <source src={`${import.meta.env.BASE_URL}Futuristic_Digital_Network_Animation.mp4`} type="video/mp4" />
    </video>
    <!-- Dark Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0b1a2b]/95 via-[#0b1a2b]/70 to-[#0b1a2b]/95"></div>
  </div>

  <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
    const video = document.getElementById('hero-video');
    const sources = [
      `${baseUrl}Futuristic_Digital_Network_Animation.webm`,
      `${baseUrl}Cinematic_Tech_Loop_Generation.webm`
    ];
    let currentIndex = 0;
    
    if (video) {
        video.addEventListener('ended', () => {
          currentIndex = (currentIndex + 1) % sources.length;
          video.style.opacity = '0';
          
          setTimeout(() => {
            video.src = sources[currentIndex];
            video.load();
            video.play();
            video.style.opacity = '0.35';
          }, 500);
        });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <div class="max-w-5xl mx-auto mb-16 animate-fade-in translate-y-8 opacity-0 [animation-delay:200ms]">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-black text-white leading-[1.05] tracking-tighter mb-8 drop-shadow-2xl">
        {title}
      </h1>
      <p class="text-xl md:text-3xl lg:text-4xl font-heading font-black text-[#5dade2]/90 tracking-tight max-w-4xl mx-auto drop-shadow-xl">
        {subtitle}
      </p>
    </div>

    <!-- Action Area (Service Cards Only) -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up opacity-0 [animation-delay:600ms]">
      <ServiceCards isHero={true} />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-20 animate-bounce opacity-40 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-[#5dade2] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
