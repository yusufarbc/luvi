---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="hero" class="relative min-h-[100dvh] w-full flex flex-col items-center justify-center pt-24 pb-12 overflow-hidden bg-[#0b1a2b]">
  <!-- ... existing video code ... -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      webkit-playsinline
      poster={`${base}/building.webp`}
      class="absolute inset-0 w-full h-full object-cover opacity-90 transition-opacity duration-1000"
    >
      <source src={`${base}/banner/1.webm`} type="video/webm" />
    </video>
    <!-- Ultra-light overlays for maximum video visibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0b1a2b]/30 via-transparent to-[#0b1a2b]/30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#0b1a2b_100%)] opacity-20"></div>
  </div>

  <script>
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    
    const playlist = [
      'banner/1.webm',
      'banner/2.webm',
      'banner/3.webm'
    ];
    
    let currentIndex = 0;

    function playNextVideo() {
      if (!video) return;
      
      // Fade out
      video.style.opacity = '0';
      
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = `${window.location.origin}${import.meta.env.BASE_URL}${playlist[currentIndex]}`;
        video.load();
        video.play().then(() => {
          // Fade in
          video.style.opacity = '0.9';
        }).catch(err => console.log("Video play error:", err));
      }, 1000); // Match transition duration
    }
    
    function initVideo() {
      if (video) {
        video.muted = true;
        video.play().catch(() => {
          console.log("Video autoplay blocked, waiting for interaction");
        });
        
        video.addEventListener('ended', playNextVideo);
      }
    }

    if (video) {
        window.addEventListener('load', initVideo);
        document.addEventListener('touchstart', () => video.play(), { once: true });
        document.addEventListener('click', () => video.play(), { once: true });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center my-auto">
    <div class="transform scale-90 sm:scale-100 transition-transform duration-700">
      <!-- Main Headline with fluid typography -->
      <div class="max-w-5xl mx-auto mb-6 animate-fade-in translate-y-4 opacity-0 [animation-delay:200ms]">
        <h1 class="font-sans font-black text-white leading-[1.05] tracking-tighter drop-shadow-2xl mx-auto" style="font-size: clamp(1.6rem, 5vw, 3.5rem);">
          {t('hero.h1').split(',')[0].trim()},
          <span class="block mt-2 text-[#5dade2] drop-shadow-[0_0_30px_rgba(93,173,226,0.6)]">
            {t('hero.h1').split(',')[1].trim()}
          </span>
        </h1>
        
        <!-- Subtitle/Motto with professional secondary color -->
        <p class="mt-4 text-white/80 max-w-[700px] mx-auto leading-relaxed font-bold tracking-tight drop-shadow-md" style="font-family: var(--font-sans); text-shadow: 0 4px 12px rgba(0,0,0,0.4); font-size: clamp(0.75rem, 1.3vw, 1rem);">
          {t('hero.subtitle')}
        </p>
        
        <!-- Action Buttons -->
        <div class="mt-8 flex flex-wrap justify-center gap-6">
          <a 
            href={`#contact`}
            class="px-10 py-4 bg-[#5dade2] text-white rounded-2xl font-sans text-lg font-black tracking-widest hover:bg-white hover:text-[#5dade2] hover:shadow-[0_20px_60px_rgba(93,173,226,0.4)] transition-all duration-500 transform hover:-translate-y-2 active:scale-95 border-2 border-[#5dade2]"
          >
            {lang === 'tr' ? 'Bizimle iletişime geçin' : 'Contact us now'}
          </a>
        </div>
      </div>
    </div>

    <!-- Service Cards Integration -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up opacity-0 [animation-delay:600ms]">
      <ServiceCards isHero={true} />
    </div>
  </div>

    <!-- Minimal Scroll Indicator -->
    <div class="mt-8 animate-bounce opacity-40 flex flex-col items-center gap-3">
      <div class="w-px h-10 bg-gradient-to-b from-[#5dade2] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
