---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroEntry = await getEntry('hero', lang);
const { title, subtitle } = heroEntry.data;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section class="relative min-h-[95vh] w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-[#0b1a2b]">
  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      loop
      playsinline 
      webkit-playsinline
      poster={`${base}/building.webp`}
      class="absolute inset-0 w-full h-full object-cover opacity-35 transition-opacity duration-1000"
    >
      <source src={`${base}/bg.webm`} type="video/webm" />
    </video>
    <!-- Dark Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0b1a2b]/95 via-[#0b1a2b]/70 to-[#0b1a2b]/95"></div>
  </div>

  <script is:inline>
    const video = document.getElementById('hero-video');
    
    function initVideo() {
      if (video) {
        video.muted = true;
        video.play().catch(() => {
          console.log("Video autoplay blocked, waiting for interaction");
        });
      }
    }

    if (video) {
        window.addEventListener('load', initVideo);
        document.addEventListener('touchstart', () => video.play(), { once: true });
        document.addEventListener('click', () => video.play(), { once: true });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <div class="max-w-6xl mx-auto mb-16 animate-fade-in translate-y-8 opacity-0 [animation-delay:200ms]">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-black text-white leading-[1.1] tracking-tighter drop-shadow-2xl">
        {title}
        <span class="block mt-6 text-[#5dade2] md:text-6xl lg:text-7xl leading-tight">
          {subtitle}
        </span>
      </h1>
    </div>

    <!-- Action Area (Service Cards Only) -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up opacity-0 [animation-delay:600ms]">
      <ServiceCards isHero={true} />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-20 animate-bounce opacity-40 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-[#5dade2] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
