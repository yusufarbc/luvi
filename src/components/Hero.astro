---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative min-h-[90vh] w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-[#050a10]">
  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover opacity-60 transition-opacity duration-1000"
    >
      <source src={`${import.meta.env.BASE_URL}Futuristic_Digital_Network_Animation.mp4`} type="video/mp4" />
    </video>
    <!-- Overlay for Readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#050a10]/80 via-[#050a10]/40 to-[#050a10]"></div>
  </div>

  <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
    const video = document.getElementById('hero-video');
    const sources = [
      `${baseUrl}Futuristic_Digital_Network_Animation.mp4`,
      `${baseUrl}Cinematic_Tech_Loop_Generation.mp4`
    ];
    let currentIndex = 0;

    if (video) {
      video.addEventListener('ended', () => {
        currentIndex = (currentIndex + 1) % sources.length;
        video.style.opacity = '0';
        
        setTimeout(() => {
          video.src = sources[currentIndex];
          video.load();
          video.play();
          video.style.opacity = '0.6';
        }, 500);
      });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <!-- Corporate Badge -->
    <div class="inline-flex items-center gap-3 px-6 py-2 rounded-full bg-white/5 border border-white/10 mb-10 shadow-sm animate-fade-in backdrop-blur-sm">
      <span class="w-1.5 h-1.5 bg-[#5dade2] rounded-full animate-pulse"></span>
      <span class="text-white/80 text-[10px] font-sans font-bold uppercase tracking-[0.4em]">{t('hero.h2')}</span>
    </div>

    <!-- H1 Headline -->
    <div class="max-w-5xl mx-auto">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-black text-white mb-10 leading-[1.1] tracking-tighter drop-shadow-2xl">
        {t('hero.h1')}
      </h1>
      <div class="w-24 h-1 bg-[#5dade2] mx-auto rounded-full mb-16 shadow-[0_0_20px_rgba(93,173,226,0.5)]"></div>
    </div>

    <!-- Action Area -->
    <div class="mt-8 transition-all duration-1000 animate-slide-up">
      <ServiceCards isHero={true} />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-20 animate-bounce opacity-40 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-white/40 to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
