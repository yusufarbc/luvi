---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const latestNews = await getCollection('projects', ({ data }) => data.lang === lang);
const newsItems = latestNews.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section class="relative min-h-screen w-full flex flex-col items-center justify-center pt-32 pb-24 overflow-hidden bg-[#0b1a2b]">
  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      webkit-playsinline
      poster={`${base}/building.webp`}
      class="absolute inset-0 w-full h-full object-cover opacity-40 transition-opacity duration-1000"
    >
      <source src={`${base}/banner/1.webm`} type="video/webm" />
    </video>
    <!-- Dark Gradient Overlay (Refined for better readability) -->
    <div class="absolute inset-0 bg-gradient-to-br from-[#0b1a2b]/95 via-[#0b1a2b]/60 to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_50%,rgba(93,173,226,0.15)_0%,transparent_50%)]"></div>
  </div>

  <script is:inline>
    const video = document.getElementById('hero-video');
    const playlist = ['banner/1.webm', 'banner/2.webm', 'banner/3.webm'];
    let currentIndex = 0;
    function playNextVideo() {
      if (!video) return;
      video.style.opacity = '0';
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = `${window.location.origin}${import.meta.env.BASE_URL}${playlist[currentIndex]}`;
        video.load();
        video.play().then(() => { video.style.opacity = '0.4'; }).catch(err => console.log(err));
      }, 1000);
    }
    if (video) {
        video.addEventListener('ended', playNextVideo);
        document.addEventListener('touchstart', () => video.play(), { once: true });
        document.addEventListener('click', () => video.play(), { once: true });
    }
  </script>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 md:px-8 h-full flex flex-col justify-center">
    <div class="flex flex-col lg:flex-row items-center gap-20">
      <!-- Left Side: Motto & CTA -->
      <div class="w-full lg:w-3/5 text-left animate-fade-in translate-y-8 opacity-0 [animation-delay:200ms]">
        <h1 class="text-5xl md:text-7xl lg:text-7xl font-heading font-black text-white leading-[1.1] tracking-tighter drop-shadow-2xl mb-8">
          "{t('hero.h1')}"
        </h1>
        <p class="text-xl md:text-2xl text-white/60 mb-12 max-w-2xl font-black tracking-tight" style="font-family: var(--font-motto);">
          {t('hero.subtitle')}
        </p>
        
        <div class="flex flex-wrap gap-6">
          <a 
            href={`#contact`}
            class="px-12 py-6 bg-[#e74c3c] text-white rounded-xl font-heading font-black text-lg uppercase tracking-widest hover:bg-white hover:text-[#e74c3c] hover:shadow-[0_20px_40px_rgba(231,76,60,0.4)] transition-all duration-500 transform hover:-translate-y-1 active:scale-95"
          >
            {t('hero.contact')}
          </a>
        </div>

        <!-- Slider Indicators (Visual Only) -->
        <div class="mt-20 flex gap-3 h-1">
          <div class="w-16 h-full bg-[#e74c3c]"></div>
          <div class="w-8 h-full bg-white/20"></div>
          <div class="w-8 h-full bg-white/20"></div>
          <div class="w-8 h-full bg-white/20"></div>
        </div>
      </div>

      <!-- Right Side: News Cards -->
      <div class="w-full lg:w-2/5 flex flex-col items-end gap-6 mt-12 lg:mt-64 transition-all duration-1000 animate-slide-up opacity-0 [animation-delay:600ms]">
         <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4 w-full">
            {newsItems.map((news) => (
              <a href={`${base}/${lang}/projects/${news.id.split('/').pop()?.replace('.md', '')}`} class="group relative aspect-video rounded-2xl overflow-hidden border border-white/10 shadow-2xl transition-all duration-500 hover:scale-105 hover:border-[#e74c3c]/50">
                <img src={`${base}${news.data.image}`} alt={news.data.title} class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-all duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
                <div class="absolute bottom-4 left-4 right-4">
                  <h3 class="text-white font-black text-[10px] md:text-[11px] uppercase tracking-wider mb-1 line-clamp-2">
                    {news.data.title}
                  </h3>
                </div>
              </a>
            ))}
            <a href={`${base}/${lang}/#projects`} class="flex flex-col items-center justify-center p-6 border-2 border-white/20 rounded-2xl text-white font-black uppercase tracking-widest text-xs hover:bg-white hover:text-[#0b1a2b] transition-all group">
              <span class="mb-2 transition-transform group-hover:translate-x-2">Tümünü Gör</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </a>
         </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-40">
      <div class="w-px h-12 bg-gradient-to-b from-[#e74c3c] to-transparent"></div>
    </div>
  </div>
</section>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

