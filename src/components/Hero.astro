---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ServiceCards from './ServiceCards.astro';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroEntry = await getEntry('hero', lang);
const { title, subtitle } = heroEntry.data;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

  <!-- Background Layers (Video) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="hero-video"
      autoplay 
      muted 
      playsinline 
      webkit-playsinline
      poster={`${base}/building.webp`}
      class="absolute inset-0 w-full h-full object-cover opacity-90 transition-opacity duration-1000"
    >
      <source src={`${base}/banner/1.webm`} type="video/webm" />
    </video>
    <!-- Ultra-light overlays for maximum video visibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0b1a2b]/30 via-transparent to-[#0b1a2b]/30"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#0b1a2b_100%)] opacity-20"></div>
  </div>

  <script>
    const video = document.getElementById('hero-video') as HTMLVideoElement;
    const base = (video?.closest('section')?.parentElement?.dataset.base || '') as string;
    
    const playlist = [
      'banner/1.webm',
      'banner/2.webm',
      'banner/3.webm',
      'banner/4.webm',
      'banner/5.webm'
    ];
    
    let currentIndex = 0;

    function playNextVideo() {
      if (!video) return;
      
      // Fade out
      video.style.opacity = '0';
      
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % playlist.length;
        video.src = `${window.location.origin}${import.meta.env.BASE_URL}${playlist[currentIndex]}`;
        video.load();
        video.play().then(() => {
          // Fade in
          video.style.opacity = '0.6';
        }).catch(err => console.log("Video play error:", err));
      }, 1000); // Match transition duration
    }
    
    function initVideo() {
      if (video) {
        video.muted = true;
        video.play().catch(() => {
          console.log("Video autoplay blocked, waiting for interaction");
        });
        
        video.addEventListener('ended', playNextVideo);
      }
    }

    if (video) {
        window.addEventListener('load', initVideo);
        document.addEventListener('touchstart', () => video.play(), { once: true });
        document.addEventListener('click', () => video.play(), { once: true });
    }
  </script>

  <!-- Content Layer -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 text-center">
    <div class="max-w-5xl mx-auto mb-10 animate-fade-in translate-y-8 opacity-0 [animation-delay:200ms]">
      <h1 class="font-sans font-black text-white leading-[1.05] tracking-tighter drop-shadow-2xl mx-auto" style="font-size: clamp(2.5rem, 6vw, 5rem);">
        {t('hero.h1').split(',')[0].trim()},
        <span class="block mt-4 text-[#5dade2] drop-shadow-[0_0_30px_rgba(93,173,226,0.6)]">
          {t('hero.h1').split(',')[1].trim()}
        </span>
      </h1>
      <p class="mt-4 text-white/80 max-w-[700px] mx-auto leading-relaxed font-bold tracking-tight drop-shadow-md" style="font-family: var(--font-sans); text-shadow: 0 4px 12px rgba(0,0,0,0.4); font-size: clamp(0.9rem, 1.2vw, 1.25rem);">
        {t('hero.subtitle')}
      </p>
      
      <div class="mt-8 flex flex-wrap justify-center gap-6">
        <a 
          href={`#contact`}
          class="px-10 py-5 bg-[#5dade2] text-white rounded-2xl font-sans text-lg font-black tracking-widest hover:bg-white hover:text-[#5dade2] hover:shadow-[0_20px_60px_rgba(93,173,226,0.4)] transition-all duration-500 transform hover:-translate-y-2 active:scale-95 border-2 border-[#5dade2]"
        >
          {lang === 'tr' ? 'Bizimle iletişime geçin' : 'Contact us now'}
        </a>
      </div>
    </div>

      <ServiceCards isHero={true} />
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-40 animate-bounce opacity-40 flex flex-col items-center gap-3">
      <div class="w-px h-16 bg-gradient-to-b from-[#5dade2] to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .animate-slow-spin {
    animation: slow-spin 60s linear infinite;
  }
  @keyframes slow-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-slide-up {
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
