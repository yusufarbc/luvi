---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const maturityEntry = await getEntry('maturity', lang);
const { title, subtitle, description, cta, status } = maturityEntry.data;
---

<section id="maturity" class="py-32 relative overflow-hidden bg-white">
  <!-- Subtle Background Pattern -->
  <div class="absolute inset-0 bg-slate-50/50 opacity-30"></div>

  <div class="container mx-auto px-4 md:px-8 relative z-10">
    <div class="max-w-4xl mx-auto bg-white border border-slate-100 p-8 md:p-20 rounded-[48px] text-center shadow-sm hover:shadow-xl transition-shadow duration-700">
      <div class="inline-flex items-center gap-3 px-6 py-2 rounded-full bg-slate-50 border border-slate-100 mb-10">
        <span class="w-1.5 h-1.5 bg-[#5dade2] rounded-full"></span>
        <span class="text-[#154360] text-[10px] font-sans font-black uppercase tracking-[0.4em]">{title}</span>
      </div>
      
      <h2 class="text-4xl md:text-7xl font-heading font-black text-[#154360] mb-10 leading-tight tracking-tighter">
        {subtitle}
      </h2>
      
      <p class="text-slate-500 text-xl md:text-2xl font-sans leading-relaxed mb-14 max-w-2xl mx-auto">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-8">
        <a 
          href="#contact" 
          class="px-14 py-6 bg-[#154360] text-white rounded-2xl font-heading font-black uppercase tracking-widest hover:bg-[#5dade2] transition-all duration-300 shadow-xl shadow-blue-900/10"
        >
          {cta}
        </a>
        <span class="text-slate-400 text-xs font-sans font-black tracking-[0.3em] uppercase opacity-60">{status}</span>
      </div>
    </div>
  </div>
</section>
