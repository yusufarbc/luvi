---
import { getCollection, getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sectionEntry = await getEntry('sections', `references-${lang}`);
const { ref_title, ref_subtitle } = sectionEntry.data;

const allReferences = await getCollection('references', ({ data }) => {
  return data.lang === lang;
});

const sortedReferences = allReferences.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="references" class="py-24 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-heading font-black text-[#154360] uppercase tracking-tighter leading-tight">
        {ref_title}
      </h2>
    </div>

    <div class="relative overflow-hidden w-full py-10">
      <div class="flex animate-scroll hover:[animation-play-state:paused] whitespace-nowrap gap-10 md:gap-14 w-max">
        {/* Original List */}
        {sortedReferences.map((r) => (
          <a 
            href={r.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative py-8 px-12 transition-all duration-500 flex items-center justify-center min-w-[200px] md:min-w-[260px]"
          >
            {r.data.logo ? (
              <img 
                src={`${base}${r.data.logo}`} 
                alt={r.data.name} 
                class="max-h-20 w-auto max-w-[85%] object-contain transition-transform duration-500 group-hover:scale-110"
              />
            ) : (
              <span class="text-[#154360] font-heading font-black text-xl md:text-3xl tracking-tighter uppercase">
                {r.data.name}
              </span>
            )}
          </a>
        ))}
        {/* Duplicate list for seamless loop */}
        {sortedReferences.map((r) => (
          <a 
            href={r.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative py-8 px-12 transition-all duration-500 flex items-center justify-center min-w-[200px] md:min-w-[260px]"
          >
            {r.data.logo ? (
              <img 
                src={`${base}${r.data.logo}`} 
                alt={r.data.name} 
                class="max-h-20 w-auto max-w-[85%] object-contain transition-transform duration-500 group-hover:scale-110"
              />
            ) : (
              <span class="text-[#154360] font-heading font-black text-xl md:text-3xl tracking-tighter">
                {r.data.name}
              </span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 28px)); }
  }
  .animate-scroll {
    animation: scroll 40s linear infinite;
  }
  @media (max-width: 768px) {
    .animate-scroll {
      animation: scroll 25s linear infinite;
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 20px)); }
    }
  }
</style>
