---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-white border-t border-slate-100 pt-24 pb-12">
  <div class="container mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-24">
      <!-- Brand Section -->
      <div class="flex flex-col gap-8">
        <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Luvi Bilişim" class="h-12 w-auto object-contain self-start opacity-90" />
        <p class="text-slate-500 font-sans text-base leading-relaxed max-w-sm">
          {t('hero.h1')}
        </p>
      </div>

      <!-- Quick Links (Simplified) -->
      <div class="flex flex-col gap-10">
        <h4 class="text-[#154360] font-heading font-black uppercase tracking-[0.3em] text-[10px] mb-2">{t('footer.contact')}</h4>
        <div class="flex flex-col gap-10">
          <div class="flex flex-col">
            <span class="text-slate-400 text-[9px] uppercase font-black tracking-widest mb-4">{t('footer.email')}</span>
            <a href={`mailto:${t('footer.contact_email')}`} class="text-[#154360] hover:text-[#5dade2] transition-colors font-heading text-xl font-black underline underline-offset-8 decoration-slate-100 hover:decoration-[#5dade2]">{t('footer.contact_email')}</a>
          </div>
          <div class="flex flex-col">
            <span class="text-slate-400 text-[9px] uppercase font-black tracking-widest mb-4">{t('footer.address')}</span>
            <p class="text-slate-500 text-sm font-sans leading-relaxed">
              {t('footer.address_val')}
            </p>
          </div>
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-10">
        <h4 class="text-[#154360] font-heading font-black uppercase tracking-[0.3em] text-[10px] mb-2">SOSYAL MEDYA</h4>
        <div class="flex flex-wrap gap-4">
          <!-- WhatsApp -->
          <div class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.89 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.744-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          </div>
          <!-- Instagram -->
          <div class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <!-- Facebook -->
          <div class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </div>
          <!-- LinkedIn -->
          <div class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <!-- X -->
          <div class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932 6.064-6.932zm-1.293 19.494h2.039L6.482 2.818h-2.19L17.608 20.647z"/></svg>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-slate-50 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-slate-400 text-[10px] font-sans font-black tracking-widest">
        &copy; {currentYear} LUVI BİLİŞİM. {t('footer.rights')}
      </p>
      <p class="text-[#154360] text-[10px] tracking-[0.5em] font-black uppercase opacity-20">
        BİLİŞİM TEKNOLOJİ İNOVASYON DİJİTALLEŞME
      </p>
    </div>
  </div>
</footer>
