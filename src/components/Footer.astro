---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-[#050b14] border-t border-[#c9a84c]/20 pt-20 pb-10">
  <div class="container mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <!-- Brand Section -->
      <div class="flex flex-col gap-6">
        <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Luvi Bilişim" class="h-10 w-auto object-contain self-start" />
        <p class="text-white/60 font-sans text-sm leading-relaxed max-w-xs">
          {t('hero.h1')}
        </p>
      </div>

      <!-- Quick Links (Simplified) -->
      <div class="flex flex-col gap-6">
        <h4 class="text-[#c9a84c] font-sans font-bold uppercase tracking-widest text-sm">{t('footer.contact')}</h4>
        <div class="flex flex-col gap-6">
          <div class="flex flex-col">
            <span class="text-white/40 text-xs uppercase tracking-tighter mb-1">{t('footer.email')}</span>
            <a href={`mailto:${t('footer.contact_email')}`} class="text-white hover:text-[#c9a84c] transition-colors font-sans decoration-[#c9a84c]/30 underline underline-offset-4">{t('footer.contact_email')}</a>
          </div>
          <div class="flex flex-col">
            <span class="text-white/40 text-xs uppercase tracking-tighter mb-1">{t('footer.address')}</span>
            <p class="text-white/80 text-sm font-sans leading-relaxed">
              {t('footer.address_val')}
            </p>
          </div>
        </div>
      </div>

      <!-- Social/Newsletter (Placeholders) -->
      <div class="flex flex-col gap-6">
        <h4 class="text-[#c9a84c] font-sans font-bold uppercase tracking-widest text-sm">Social</h4>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full border border-[#c9a84c]/30 flex items-center justify-center text-[#c9a84c] hover:bg-[#c9a84c] hover:text-[#0a1628] transition-all cursor-pointer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <div class="w-10 h-10 rounded-full border border-[#c9a84c]/30 flex items-center justify-center text-[#c9a84c] hover:bg-[#c9a84c] hover:text-[#0a1628] transition-all cursor-pointer">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs font-sans">
        &copy; {currentYear} LUVI BİLİŞİM. {t('footer.rights')}
      </p>
      <p class="text-white/30 text-[10px] tracking-[0.3em] uppercase">
        LUVIALARA IŞIK İNSANLARI
      </p>
    </div>
  </div>
</footer>
