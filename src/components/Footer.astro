---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-white border-t border-slate-100 pt-24 pb-12">
  <div class="container mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-24">
      <!-- Brand Section -->
      <div class="flex flex-col gap-8">
        <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Luvi Bilişim" class="h-12 w-auto object-contain self-start opacity-90" />
        <p class="text-slate-500 font-sans text-base leading-relaxed max-w-sm">
          {t('hero.h1')}
        </p>
        <p class="text-[#5dade2] font-sans font-bold text-sm tracking-tight  leading-tight opacity-80 mt-[-20px]">
          {t('hero.motto2')}
        </p>
      </div>

      <!-- Quick Links (Simplified) -->
      <div class="flex flex-col gap-10">
        <h4 class="text-[#154360] font-sans font-bold tracking-[0.3em] text-[10px] mb-2 ">{t('footer.contact')}</h4>
        <div class="flex flex-col gap-10">
          <div class="flex flex-col">
            <span class="text-slate-400 text-[9px] font-black tracking-widest mb-4 ">{t('footer.email')}</span>
            <a href={`mailto:${t('footer.contact_email')}`} class="text-[#154360] hover:text-[#5dade2] transition-colors font-sans text-xl font-bold underline underline-offset-8 decoration-slate-100 hover:decoration-[#5dade2]">{t('footer.contact_email')}</a>
          </div>
          <div class="flex flex-col">
            <span class="text-slate-400 text-[9px] font-black tracking-widest mb-4 ">{t('footer.address')}</span>
            <p class="text-slate-500 text-sm font-sans leading-relaxed">
              {t('footer.address_val')}
            </p>
          </div>
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex flex-col gap-10">
        <h4 class="text-[#154360] font-sans font-bold tracking-[0.3em] text-[10px] mb-2 ">Sosyal Medya</h4>
        <div class="flex flex-wrap gap-4">
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/luvibilisim" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#154360] hover:text-white hover:border-[#154360] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <!-- YouTube -->
          <a href="https://www.youtube.com/@luvibilisim" target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-2xl border border-slate-100 flex items-center justify-center text-slate-400 hover:bg-[#ff0000] hover:text-white hover:border-[#ff0000] transition-all duration-500 cursor-pointer shadow-sm hover:shadow-xl">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-slate-50 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-12">
        <p class="text-slate-400 text-[10px] font-sans font-bold tracking-widest capitalize">
          &copy; {currentYear} Luvi Bilişim. {t('footer.rights')}
        </p>
        <div class="flex gap-8">
          <a href={`${import.meta.env.BASE_URL}${lang}/legal/kvkk`} class="text-slate-300 hover:text-[#154360] text-[9px] font-black tracking-widest transition-all uppercase">{lang === 'tr' ? 'KVKK' : 'KVKK'}</a>
          <a href={`${import.meta.env.BASE_URL}${lang}/legal/privacy`} class="text-slate-300 hover:text-[#154360] text-[9px] font-black tracking-widest transition-all uppercase">{lang === 'tr' ? 'Gizlilik' : 'Privacy'}</a>
          <a href={`${import.meta.env.BASE_URL}${lang}/legal/cookies`} class="text-slate-300 hover:text-[#154360] text-[9px] font-black tracking-widest transition-all uppercase">{lang === 'tr' ? 'Çerezler' : 'Cookies'}</a>
        </div>
      </div>
      <p class="text-[#154360] text-[10px] tracking-[0.5em] font-bold opacity-30 flex gap-2">
        <span>Bilişim</span>
        <span>Teknoloji</span>
        <span>İnovasyon</span>
      </p>
    </div>
  </div>
</footer>
