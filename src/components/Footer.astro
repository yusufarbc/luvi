---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-slate-950 border-t border-slate-900 pt-24 pb-12">
  <div class="container mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-20">
      <!-- Brand Section -->
      <div class="flex flex-col gap-8">
        <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Luvi Bilişim" class="h-12 w-auto object-contain self-start filter brightness-0 invert opacity-90" />
        <p class="text-slate-400 font-sans text-base leading-relaxed max-w-sm">
          {t('hero.h1')}
        </p>
      </div>

      <!-- Quick Links (Simplified) -->
      <div class="flex flex-col gap-8">
        <h4 class="text-white font-sans font-black uppercase tracking-[0.2em] text-xs mb-2">{t('footer.contact')}</h4>
        <div class="flex flex-col gap-8">
          <div class="flex flex-col">
            <span class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-2">{t('footer.email')}</span>
            <a href={`mailto:${t('footer.contact_email')}`} class="text-slate-200 hover:text-blue-400 transition-colors font-sans text-lg font-medium underline underline-offset-8 decoration-slate-800 hover:decoration-blue-500">{t('footer.contact_email')}</a>
          </div>
          <div class="flex flex-col">
            <span class="text-slate-500 text-[10px] uppercase font-bold tracking-widest mb-2">{t('footer.address')}</span>
            <p class="text-slate-300 text-sm font-sans leading-relaxed">
              {t('footer.address_val')}
            </p>
          </div>
        </div>
      </div>

      <!-- Social/Newsletter (Placeholders) -->
      <div class="flex flex-col gap-8">
        <h4 class="text-white font-sans font-black uppercase tracking-[0.2em] text-xs mb-2">Social</h4>
        <div class="flex gap-4">
          <div class="w-12 h-12 rounded-xl border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-white hover:text-slate-950 hover:border-white transition-all duration-300 cursor-pointer shadow-lg">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.761 0 5-2.239 5-5v-14c0-2.761-2.239-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <div class="w-12 h-12 rounded-xl border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-white hover:text-slate-950 hover:border-white transition-all duration-300 cursor-pointer shadow-lg">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-12 border-t border-slate-900 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-slate-600 text-xs font-sans font-bold tracking-tight">
        &copy; {currentYear} LUVI BİLİŞİM. {t('footer.rights')}
      </p>
      <p class="text-slate-700 text-[11px] tracking-[0.4em] font-black uppercase">
        LUVIALARA IŞIK İNSANLARI
      </p>
    </div>
  </div>
</footer>
