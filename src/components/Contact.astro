---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="contact-form" class="py-32 bg-slate-50 relative overflow-hidden scroll-mt-24">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-[#154360]/5 skew-x-12 transform origin-top translate-x-1/2"></div>
  
  <div class="container mx-auto px-4 md:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row gap-20 items-center">
      
      <!-- Info Column -->
      <div class="w-full lg:w-1/2">
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-sans font-black text-[#154360] tracking-tighter leading-tight mb-8">
          {lang === 'tr' ? 'Bize Ulaşın' : 'Get in Touch'}
        </h2>
        <p class="text-xl text-slate-500 font-medium leading-relaxed mb-12 max-w-lg">
          {lang === 'tr' 
            ? 'Dijital dönüşüm yolculuğunuzda size nasıl yardımcı olabileceğimizi öğrenmek için formu doldurun.' 
            : 'Fill out the form to learn how we can help you on your digital transformation journey.'}
        </p>
        
        <div class="space-y-8">
          <div class="flex items-start gap-6 group">
            <div class="w-14 h-14 rounded-2xl bg-white shadow-xl flex items-center justify-center text-[#e74c3c] group-hover:bg-[#e74c3c] group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <h4 class="text-[#154360] font-black text-sm uppercase tracking-widest mb-1">{lang === 'tr' ? 'E-posta' : 'Email'}</h4>
              <a href={`mailto:${t('footer.contact_email')}`} class="text-xl font-bold text-[#154360] hover:text-[#e74c3c] transition-colors">{t('footer.contact_email')}</a>
            </div>
          </div>
          
          <div class="flex items-start gap-6 group">
            <div class="w-14 h-14 rounded-2xl bg-white shadow-xl flex items-center justify-center text-[#e74c3c] group-hover:bg-[#e74c3c] group-hover:text-white transition-all duration-500">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <h4 class="text-[#154360] font-black text-sm uppercase tracking-widest mb-1">{lang === 'tr' ? 'Telefon' : 'Phone'}</h4>
              <a href={`tel:${t('footer.phone_val')}`} class="text-xl font-bold text-[#154360] hover:text-[#e74c3c] transition-colors">{t('footer.phone_val')}</a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Form Column -->
      <div class="w-full lg:w-1/2">
        <form id="contact-form-element" class="bg-white p-10 md:p-16 rounded-[48px] shadow-2xl relative overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div class="flex flex-col gap-3">
              <label for="name" class="text-[10px] font-black uppercase tracking-widest text-[#154360]/40 ml-1">{lang === 'tr' ? 'Ad Soyad' : 'Full Name'}</label>
              <input type="text" id="name" name="name" required class="w-full bg-slate-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-[#e74c3c] transition-all" />
            </div>
            <div class="flex flex-col gap-3">
              <label for="email" class="text-[10px] font-black uppercase tracking-widest text-[#154360]/40 ml-1">{lang === 'tr' ? 'E-posta' : 'Email'}</label>
              <input type="email" id="email" name="email" required class="w-full bg-slate-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-[#e74c3c] transition-all" />
            </div>
            
            <!-- Bot Trap (Honeypot for Formspree) -->
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none;" />
          </div>
          
          <div class="flex flex-col gap-3 mb-10">
            <label for="message" class="text-[10px] font-black uppercase tracking-widest text-[#154360]/40 ml-1">{lang === 'tr' ? 'Mesajınız' : 'Your Message'}</label>
            <textarea id="message" name="message" rows="4" required class="w-full bg-slate-50 border-none rounded-2xl px-6 py-4 focus:ring-2 focus:ring-[#e74c3c] transition-all resize-none"></textarea>
          </div>
          
          <button type="submit" class="w-full py-5 bg-[#154360] text-white rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-[#e74c3c] transition-all duration-500 shadow-xl flex items-center justify-center gap-3 group">
            <span>{lang === 'tr' ? 'Mesaj Gönder' : 'Send Message'}</span>
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </button>
          
          <div id="form-status" class="mt-6 text-center text-xs font-bold opacity-0 transition-opacity"></div>
        </form>
      </div>
      
    </div>

    <!-- Map Section -->
    <div class="mt-32 rounded-[48px] overflow-hidden border border-slate-200 shadow-2xl h-[500px] w-full group relative">
       <div class="absolute inset-0 bg-[#154360]/5 group-hover:bg-transparent transition-all pointer-events-none"></div>
       <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3128.2502592144638!2d27.20173769283049!3d38.366331705270035!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14b9618fb082a33f%3A0xb863aae743ff19ec!2sDEPARK%20Alfa-Beta%20Binalar%C4%B1%20(Dokuz%20Eyl%C3%BCl%20%C3%9Cniversitesi%20Teknopark%C4%B1)!5e0!3m2!1str!2str!4v1774456524879!5m2!1str!2str" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('#contact-form-element');
  const status = document.querySelector('#form-status');
  
  // Formspree Endpoint Configuration
  const formspreeURL = 'https://formspree.io/f/mykbzldw';

  const translations = {
    tr: {
      sending: 'Gönderiliyor...',
      success: 'Mesajınız başarıyla gönderildi. En kısa sürede size dönüş yapacağız.',
      error: 'Bir hata oluştu. Lütfen tekrar deneyin veya doğrudan e-posta ile ulaşın.'
    },
    en: {
      sending: 'Sending...',
      success: 'Your message has been sent successfully. We will get back to you soon.',
      error: 'An error occurred. Please try again or contact us directly via email.'
    }
  };

  // Determine language from URL path
  const currentLang = window.location.pathname.startsWith('/en') ? 'en' : 'tr';
  const t = translations[currentLang];

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      status.innerText = t.sending;
      status.className = 'mt-6 text-center text-xs font-bold opacity-100 text-[#154360]';
      
      const formData = new FormData(form as HTMLFormElement);

      try {
        const response = await fetch(formspreeURL, { 
          method: 'POST', 
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          status.innerText = t.success;
          status.className = 'mt-6 text-center text-xs font-bold opacity-100 text-green-600';
          (form as HTMLFormElement).reset();
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        console.error('Error!', (error as Error).message);
        status.innerText = t.error;
        status.className = 'mt-6 text-center text-xs font-bold opacity-100 text-red-600';
      }

      setTimeout(() => {
        if (status) {
          (status as HTMLElement).style.opacity = '0';
        }
      }, 5000);
    });
  }
</script>
