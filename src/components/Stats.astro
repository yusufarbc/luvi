---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    number: "5+",
    label: t('stats.projects'),
    desc: lang === 'tr' ? "Yenilikçi ve sürdürülebilir teknoloji çözümleri." : "Innovative and sustainable technology solutions."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    number: "%96",
    label: t('stats.satisfaction'),
    desc: lang === 'tr' ? "Kullanıcı odaklı hizmet anlayışımızla en yüksek memnuniyet." : "Highest satisfaction with our user-centric service approach."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>`,
    number: "10+",
    label: t('stats.platforms'),
    desc: lang === 'tr' ? "Geniş teknoloji yelpazesiyle uçtan uca dijital dönüşüm." : "End-to-end digital transformation with a wide range of technologies."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
    number: "13+",
    label: t('stats.partnerships'),
    desc: lang === 'tr' ? "Küresel markalarla güçlü ve güvenilir iş birlikleri." : "Strong and reliable collaborations with global brands."
  }
];

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section class="w-full bg-white overflow-hidden">
  <div class="flex flex-col lg:flex-row min-h-[600px]">
    <!-- Left Side: Image -->
    <div class="w-full lg:w-1/2 relative min-h-[400px] lg:min-h-0">
      <img 
        src={`${base}/images/building.webp`} 
        alt="Luvi Bilişim Stats" 
        class="absolute inset-0 w-full h-full object-cover"
      />
    </div>

    <!-- Right Side: Stats Grid -->
    <div class="w-full lg:w-1/2 grid grid-cols-1 md:grid-cols-2">
      {stats.map((stat) => (
        <div class="p-12 md:p-16 flex flex-col items-start justify-center border-b border-r border-slate-100 last:border-b-0 last:border-r-0 md:even:border-r-0 bg-white hover:bg-slate-50 transition-colors duration-500">
          <div class="text-[#e74c3c] mb-8" set:html={stat.icon} />
          <p class="text-sm text-[#154360]/60 font-black tracking-widest mb-4 text-left leading-relaxed max-w-[200px]">
            {stat.desc}
          </p>
          <div class="flex flex-col items-start">
            <span class="text-5xl md:text-6xl lg:text-7xl font-heading font-black text-[#154360] tracking-tighter mb-2">
              {stat.number}
            </span>
            <span class="text-xs font-black text-[#154360]/40 tracking-widest">
              {stat.label}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
