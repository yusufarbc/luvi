---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  isHero?: boolean;
}

const { isHero = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allServices = await getCollection('services', ({ data }) => {
  return data.lang === lang;
});

const imageMap: Record<string, string> = {
  strategy: '/services/strategy.webp',
  security: '/services/security.webp',
  professional: '/services/ai.webp',
  compliance: '/services/compliance.webp',
  transformation: '/services/transformation.webp',
  excellence: '/services/excellence.webp',
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="services" class="py-40 bg-white relative overflow-hidden scroll-mt-32">
    <!-- Subtle Background Pattern -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#154360 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="container mx-auto px-4 md:px-8 relative z-10">
        <!-- Section Header: Corporate Left-Aligned -->
        <div class="flex flex-col lg:flex-row items-end justify-between mb-32 gap-12">
            <div class="max-w-3xl">
                <span class="inline-flex items-center gap-3 text-[#5dade2] font-sans font-black text-xs tracking-[0.4em] mb-8">
                    <div class="w-12 h-px bg-[#5dade2]/30"></div>
                    {lang === 'tr' ? 'STRATEJİK ÇÖZÜMLERİMİZ' : 'STRATEGIC SOLUTIONS'}
                </span>
                <h2 class="text-4xl md:text-7xl font-sans font-black text-[#154360] tracking-tighter leading-[1] mb-8">
                    {lang === 'tr' ? (
                        <>Stratejik Çözümler <br/> ve <span class="text-slate-400">Dijital Yetkinlikler</span></>
                    ) : (
                        <>Strategic Solutions <br/> and <span class="text-slate-400">Digital Competencies</span></>
                    )}
                </h2>
                <p class="text-slate-500 text-xl font-medium leading-relaxed max-w-2xl border-l-[6px] border-[#e74c3c] pl-8 py-2">
                    {lang === 'tr' 
                        ? 'İşletmenizin dijital dayanıklılığını ve operasyonel verimliliğini global standartlarda, uçtan uca yönetilen profesyonel hizmetlerle güçlendiriyoruz.' 
                        : 'We empower your digital resilience and operational efficiency with end-to-end managed professional services at global standards.'}
                </p>
            </div>
        </div>

        {allServices.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {allServices
              .sort((a, b) => (a.data.order || 99) - (b.data.order || 99))
              .map((s) => (
              <a 
                href={`${base}/${lang}/services/${s.slug || (() => {
                  let id = (s.id || '').toString();
                  if (id.endsWith('.md')) id = id.replace(/\.md$/, '');
                  const parts = id.split('/').filter(Boolean);
                  let ss = parts.length ? parts[parts.length - 1] : '';
                  if (ss === 'tr' || ss === 'en') ss = parts.length >= 2 ? parts[parts.length - 2] : ss;
                  return ss;
                })()}`}
                class="group relative flex flex-col bg-white border border-slate-100 p-10 rounded-[40px] transition-all duration-1000 hover:border-[#5dade2]/30 hover:shadow-[0_60px_100px_-30px_rgba(21,67,160,0.12)]"
              >
                <!-- Numbering Overlay -->
                <div class="absolute top-10 right-10 text-slate-100 font-sans font-black text-6xl select-none group-hover:text-[#5dade2]/10 transition-colors duration-700">
                    {s.data.order < 10 ? `0${s.data.order}` : s.data.order}
                </div>

                <!-- 3D Image Focal Point -->
                <div class="relative w-full aspect-square mb-12 rounded-[32px] overflow-hidden bg-slate-50 transition-all duration-1000 group-hover:scale-[1.05] group-hover:rotate-1">
                  <img 
                    src={imageMap[s.data.category] || '/services/strategy.webp'} 
                    alt={s.data.title}
                    class="w-full h-full object-cover transform transition-transform duration-[2000ms] group-hover:scale-125"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#154360]/20 to-transparent"></div>
                </div>
    
                <!-- Title & Description -->
                <div class="flex flex-col flex-grow relative z-10">
                    <h3 class="font-sans font-black text-2xl leading-tight tracking-tight text-[#154360] mb-6 group-hover:text-[#5dade2] transition-colors duration-500">
                        {s.data.title}
                    </h3>
                    <p class="text-slate-400 text-sm leading-relaxed mb-10 line-clamp-3 group-hover:text-slate-600 transition-colors duration-500">
                        {s.data.description}
                    </p>

                    <!-- Professional Footer -->
                    <div class="mt-auto flex items-center justify-between border-t border-slate-50 pt-8">
                        <span class="text-[10px] font-sans font-black tracking-[0.3em] text-[#154360]/40 group-hover:text-[#e74c3c] transition-colors duration-500">
                           {lang === 'tr' ? 'DETAYLI ANALİZ' : 'DETAILED ANALYSIS'}
                        </span>
                        <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-[#154360] group-hover:bg-[#154360] group-hover:text-white transition-all duration-500 group-hover:translate-x-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                            </svg>
                        </div>
                    </div>
                </div>
              </a>
            ))}
          </div>
        ) : null}
    </div>
</section>
