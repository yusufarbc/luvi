---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allServices = await getCollection('services', ({ data }) => {
  return data.lang === lang;
});

// Map icon names to SVG strings (matching previous design)
const iconMap: Record<string, string> = {
  cloud: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>`,
  data: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" /></svg>`,
  security: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
  ai: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
};
---

<section id="services" class="py-24 bg-[#050b14]">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 w-full max-w-7xl mx-auto px-4 mt-16">
  {allServices.map((s) => (
    <div class="group relative bg-[#0a1628]/40 backdrop-blur-xl border border-[#c9a84c]/30 p-8 rounded-2xl transition-all duration-500 hover:-translate-y-2 hover:border-[#c9a84c] hover:shadow-[0_0_30px_rgba(201,168,76,0.2)] flex flex-col items-center text-center overflow-hidden">
      <!-- Glow Effect -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#c9a84c]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
      
      <!-- Icon Wrapper -->
      <div class="mb-6 text-[#c9a84c] group-hover:text-white transition-all duration-500 transform group-hover:scale-110 group-hover:drop-shadow-[0_0_10px_rgba(201,168,76,0.5)]">
        <Fragment set:html={iconMap[s.data.icon]} />
      </div>

      <!-- Title -->
      <h3 class="text-white font-serif text-lg tracking-wide group-hover:text-[#c9a84c] transition-colors duration-300">
        {s.data.title}
      </h3>
    </div>
  ))}

  <!-- Digital Maturity Placeholder Card -->
  <div class="group relative bg-[#c9a84c]/5 backdrop-blur-xl border border-[#c9a84c]/20 p-8 rounded-2xl transition-all duration-500 hover:border-[#c9a84c] flex flex-col items-center text-center overflow-hidden border-dashed">
    <div class="mb-6 text-[#c9a84c]/50">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
      </svg>
    </div>
    <h3 class="text-white/50 font-serif text-lg tracking-wide uppercase">
      {t('nav.maturity')} <br/>
      <span class="text-xs text-[#c9a84c] tracking-[0.2em]">{t('nav.blog') === 'Blog' ? '(Yakında)' : '(Coming Soon)'}</span>
    </h3>
  </div>
  </div>
</section>
