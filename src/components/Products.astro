---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProducts = await getCollection('products', ({ data }) => {
  return data.lang === lang;
});

const sortedProducts = allProducts.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="products" class="py-24 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-[#5dade2] font-sans font-black tracking-[0.4em] uppercase text-[9px] mb-4">
        {t('products.title')}
      </h2>
      <p class="text-4xl md:text-6xl font-heading font-black text-[#154360] uppercase tracking-tighter">
        {t('products.subtitle')}
      </p>
    </div>

    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-12">
      {sortedProducts.map((p) => (
        <a 
          href={`${base}/${lang}/products/${p.id.split('/').pop()?.replace('.md', '')}`}
          class="group relative py-8 px-14 bg-white border border-slate-100 rounded-2xl transition-all duration-500 hover:border-[#154360]/30 hover:shadow-[0_20px_40px_-10px_rgba(21,67,96,0.05)] opacity-60 hover:opacity-100 transform hover:-translate-y-1 flex items-center justify-center min-w-[240px] h-[120px]"
        >
          {p.data.logo ? (
            <img 
              src={`${base}${p.data.logo}`} 
              alt={p.data.title} 
              class="max-h-12 w-auto object-contain transition-transform duration-500 group-hover:scale-110"
            />
          ) : (
            <span class="text-[#154360] font-heading font-black text-xl md:text-3xl tracking-tighter transition-colors uppercase group-hover:scale-110 transition-transform">
              {p.data.title.split(' ')[0]}
            </span>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
