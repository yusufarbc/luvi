---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allProducts = await getCollection('products', ({ data }) => {
  return data.lang === lang;
});

const sortedProducts = allProducts.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="products" class="py-24 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-[#5dade2] font-sans font-black tracking-[0.4em] uppercase text-[9px] mb-4">
        {t('products.title')}
      </h2>
      <p class="text-4xl md:text-6xl font-heading font-black text-[#154360] uppercase tracking-tighter">
        {t('products.subtitle')}
      </p>
    </div>

    <div class="relative overflow-hidden w-full py-10">
      <div class="flex animate-scroll hover:[animation-play-state:paused] whitespace-nowrap gap-10 md:gap-14 w-max">
        {/* Original List */}
        {sortedProducts.map((p) => (
          <a 
            href={`${base}/${lang}/products/${p.id.split('/').pop()?.replace('.md', '')}`}
            class="group relative py-8 px-12 transition-all duration-500 opacity-60 hover:opacity-100 flex items-center justify-center min-w-[200px] md:min-w-[260px]"
          >
            {p.data.logo ? (
              <img 
                src={`${base}${p.data.logo}`} 
                alt={p.data.title} 
                class="max-h-20 w-auto max-w-[85%] object-contain transition-transform duration-500 group-hover:scale-110"
              />
            ) : (
              <span class="text-[#154360] font-heading font-black text-xl md:text-3xl tracking-tighter uppercase">
                {p.data.title.split(' ')[0]}
              </span>
            )}
          </a>
        ))}
        {/* Duplicate list for seamless loop */}
        {sortedProducts.map((p) => (
          <a 
            href={`${base}/${lang}/products/${p.id.split('/').pop()?.replace('.md', '')}`}
            class="group relative py-8 px-12 transition-all duration-500 opacity-60 hover:opacity-100 flex items-center justify-center min-w-[200px] md:min-w-[260px]"
          >
            {p.data.logo ? (
              <img 
                src={`${base}${p.data.logo}`} 
                alt={p.data.title} 
                class="max-h-20 w-auto max-w-[85%] object-contain transition-transform duration-500 group-hover:scale-110"
              />
            ) : (
              <span class="text-[#154360] font-heading font-black text-xl md:text-3xl tracking-tighter uppercase">
                {p.data.title.split(' ')[0]}
              </span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 28px)); } /* -50% to loop, -28px for half of the gap (14px md gap / 2?) No, gap is between items. */
  }
  .animate-scroll {
    animation: scroll 40s linear infinite;
  }
  @media (max-width: 768px) {
    .animate-scroll {
      animation: scroll 25s linear infinite;
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 20px)); }
    }
  }
</style>
