import { getCollection, getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sectionEntry = await getEntry('sections', `partners-${lang}`);
const { title, subtitle, ref_title, ref_subtitle } = sectionEntry.data;

const allPartners = await getCollection('partners', ({ data }) => {
  return data.lang === lang;
});
const partners = allPartners.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const allReferences = await getCollection('references', ({ data }) => {
  return data.lang === lang;
});
const references = allReferences.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL.endsWith('/') 
  ? import.meta.env.BASE_URL.slice(0, -1) 
  : import.meta.env.BASE_URL;
---

<section class="py-24 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4 md:px-8">
    <!-- Solution Partners -->
    <div class="mb-32">
      <div class="text-center mb-16">
        <h2 class="text-[#5dade2] font-sans font-black tracking-[0.4em] uppercase text-[9px] mb-4">
          {title}
        </h2>
        <p class="text-3xl md:text-5xl font-heading font-black text-[#154360] uppercase tracking-tighter">
          {subtitle}
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
        {partners.map((p) => (
          <a 
            href={p.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center justify-center p-8 bg-white border border-slate-50 rounded-[32px] transition-all duration-500 hover:border-[#154360]/10 hover:shadow-xl opacity-60 hover:opacity-100 grayscale hover:grayscale-0 h-[140px] w-full"
          >
            {p.data.logo ? (
              <img 
                src={`${base}${p.data.logo}`} 
                alt={p.data.name} 
                class="max-h-12 w-auto object-contain transition-transform duration-500 group-hover:scale-110"
              />
            ) : (
              <span class="text-[#154360] font-heading font-black text-xl md:text-2xl tracking-tighter text-center uppercase group-hover:scale-110 transition-transform">
                {p.data.name}
              </span>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- References -->
    <div>
      <div class="text-center mb-16">
        <h2 class="text-[#5dade2] font-sans font-black tracking-[0.4em] uppercase text-[9px] mb-4">
          {ref_title}
        </h2>
        <p class="text-3xl md:text-5xl font-heading font-black text-[#154360] uppercase tracking-tighter">
          {ref_subtitle}
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4 md:gap-6">
        {references.map((r) => (
          <a 
            href={r.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center px-8 py-6 bg-slate-50/50 border border-slate-100 rounded-[24px] transition-all duration-500 hover:border-[#154360]/5 hover:shadow-md opacity-70 hover:opacity-100 min-w-[160px]"
          >
             {r.data.logo ? (
              <img 
                src={`${base}${r.data.logo}`} 
                alt={r.data.name} 
                class="max-h-12 w-auto object-contain transition-transform duration-500 group-hover:scale-110 grayscale hover:grayscale-0 drop-shadow-[0_2px_4px_rgba(0,0,0,0.1)]"
              />
            ) : (
              <span class="text-slate-400 group-hover:text-[#154360] font-heading font-black text-sm md:text-base tracking-tighter text-center uppercase transition-colors">
                {r.data.name}
              </span>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
