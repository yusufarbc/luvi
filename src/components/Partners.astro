---
import { getCollection, getEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const sectionEntry = await getEntry('sections', `partners-${lang}`);
const { title, subtitle, ref_title, ref_subtitle } = sectionEntry.data;

const allPartners = await getCollection('partners', ({ data }) => {
  return data.lang === lang;
});
const partners = allPartners.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const allReferences = await getCollection('references', ({ data }) => {
  return data.lang === lang;
});
const references = allReferences.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const base = import.meta.env.BASE_URL.endsWith('/') 
  ? import.meta.env.BASE_URL.slice(0, -1) 
  : import.meta.env.BASE_URL;
---

<section class="py-24 bg-white border-t border-slate-100 overflow-hidden">
  <div class="container mx-auto px-4 md:px-8">
    <!-- Solution Partners -->
    <div class="mb-32">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-heading font-black text-[#154360] uppercase tracking-tighter leading-tight">
          {subtitle}
        </h2>
      </div>

      <div class="relative overflow-hidden w-full py-8">
        <div class="flex animate-scroll-fast hover:[animation-play-state:paused] whitespace-nowrap gap-12 md:gap-20 w-max">
          {/* Partners Loop x2 */}
          {[...partners, ...partners].map((p) => (
            <a 
              href={p.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col items-center justify-center px-16 py-6 bg-white border border-slate-50 rounded-[32px] transition-all duration-500 hover:border-[#154360]/10 hover:shadow-xl opacity-60 hover:opacity-100 grayscale hover:grayscale-0 h-[140px] w-auto"
            >
              {p.data.logo ? (
                <img 
                  src={`${base}${p.data.logo}`} 
                  alt={p.data.name} 
                  class="max-h-16 w-auto max-w-none object-contain transition-transform duration-500 group-hover:scale-110"
                />
              ) : (
                <span class="text-[#154360] font-heading font-black text-lg md:text-xl tracking-tighter text-center uppercase group-hover:scale-110 transition-transform whitespace-nowrap">
                  {p.data.name}
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- References -->
    <div class="pb-12">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-heading font-black text-[#154360] uppercase tracking-tighter leading-tight">
          {ref_subtitle}
        </h2>
      </div>

      <div class="relative overflow-hidden w-full py-8">
        <div class="flex animate-scroll-slow hover:[animation-play-state:paused] whitespace-nowrap gap-8 md:gap-12 w-max iterate-reverse">
          {/* References Loop x2 */}
          {[...references, ...references].map((r) => (
            <a 
              href={r.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-center px-12 py-10 bg-slate-50/50 border border-slate-100 rounded-[28px] transition-all duration-500 hover:border-[#154360]/5 hover:shadow-md opacity-70 hover:opacity-100 w-auto h-[120px]"
            >
               {r.data.logo ? (
                <img 
                  src={`${base}${r.data.logo}`} 
                  alt={r.data.name} 
                  class="max-h-16 w-auto max-w-none object-contain transition-transform duration-500 group-hover:scale-110 grayscale hover:grayscale-0 drop-shadow-[0_2px_4px_rgba(0,0,0,0.05)]"
                />
              ) : (
                <span class="text-slate-400 group-hover:text-[#154360] font-heading font-black text-sm md:text-base tracking-tighter text-center uppercase transition-colors whitespace-nowrap">
                  {r.data.name}
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-ltr {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 40px)); }
  }
  @keyframes scroll-rtl {
    0% { transform: translateX(calc(-50% - 24px)); }
    100% { transform: translateX(0); }
  }
  
  .animate-scroll-fast {
    animation: scroll-ltr 50s linear infinite;
  }
  
  .animate-scroll-slow {
    animation: scroll-rtl 70s linear infinite;
  }

  @media (max-width: 768px) {
    .animate-scroll-fast {
      animation-duration: 30s;
    }
    .animate-scroll-slow {
      animation-duration: 45s;
    }
  }
</style>
