---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featuresEntry = await getEntry('features', lang);
const { title, subtitle, items } = featuresEntry.data;
---

<section class="py-24 bg-white border-y border-slate-100 relative overflow-hidden">
  <!-- Subtle Background Grid -->
  <div class="absolute inset-0 opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(#154360 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="container mx-auto px-4 md:px-8 relative z-10">
    <div class="text-center mb-20">
      <h2 class="text-[#5dade2] font-sans font-black tracking-[0.4em] uppercase text-[10px] mb-4">
        {subtitle}
      </h2>
      <h3 class="text-4xl md:text-7xl font-heading font-black text-[#154360] mb-6 tracking-tighter">
        {title}
      </h3>
      <div class="w-16 h-1 bg-[#154360] rounded-full mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
      {items.map((f) => (
        <div class="group flex flex-col items-center text-center">
          <div class="w-24 h-24 rounded-[32px] border border-slate-100 bg-white flex items-center justify-center text-4xl mb-10 group-hover:bg-[#154360]/5 group-hover:border-[#154360]/10 transition-all duration-500 transform group-hover:-translate-y-2 shadow-sm group-hover:shadow-xl group-hover:shadow-blue-900/5">
            {f.icon}
          </div>
          <h4 class="text-[#154360] font-heading font-black text-2xl mb-4 tracking-tighter group-hover:text-[#5dade2] transition-colors">
             {f.title}
          </h4>
          <p class="text-slate-500 font-sans text-lg leading-relaxed max-w-xs">
             {f.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
