---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featuresEntry = await getEntry('features', lang);
const { title, subtitle, items } = featuresEntry.data;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="why-luvi" class="py-32 bg-[#0b1a2b] relative overflow-hidden">
  <!-- Interactive Background Mesh -->
  <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
     <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-[#5dade2]/20 blur-[120px] rounded-full animate-pulse-glow"></div>
     <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-[#154360]/30 blur-[120px] rounded-full animate-pulse-glow" style="animation-delay: 2s;"></div>
  </div>

  <!-- Decorative Overlay Grid -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 80px 80px;"></div>

  <div class="container mx-auto px-4 md:px-8 relative z-10">
    <div class="text-center mb-24 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-7xl font-heading font-black text-white mb-8 tracking-tighter leading-[1.05] drop-shadow-sm">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {items.map((f, i) => (
        <div class="group relative bg-[#154360]/10 border border-white/5 rounded-[48px] overflow-hidden backdrop-blur-3xl transition-all duration-700 hover:border-[#5dade2]/30 hover:shadow-[0_40px_100px_-20px_rgba(93,173,226,0.15)] hover:-translate-y-4">
          
          <!-- Image Container -->
          <div class="relative h-64 overflow-hidden">
             <img 
               src={`${base}${f.image}`} 
               alt={f.title} 
               class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
               loading="lazy"
               decoding="async"
             />
             <!-- Overlay Gradient -->
             <div class="absolute inset-0 bg-gradient-to-t from-[#0b1a2b] to-transparent opacity-80"></div>
          </div>

          <div class="p-10 relative z-10">
            <h4 class="text-white font-heading font-black text-2xl lg:text-3xl mb-6 tracking-tighter group-hover:text-[#5dade2] transition-colors leading-tight">
               {f.title}
            </h4>
            
            <p class="text-white/40 font-sans text-lg leading-relaxed group-hover:text-white/70 transition-colors duration-500 font-normal">
               {f.desc}
            </p>
          </div>

          <!-- Glossy Reflection (Bottom) -->
          <div class="absolute bottom-0 right-0 w-32 h-32 bg-[#5dade2]/5 blur-3xl rounded-full group-hover:bg-[#5dade2]/10 transition-colors"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes pulse-glow {
    0%, 100% { opacity: 0.1; filter: blur(120px); }
    50% { opacity: 0.3; filter: blur(150px); }
  }
  .animate-pulse-glow {
    animation: pulse-glow 6s ease-in-out infinite;
  }
</style>
