---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<section class="py-24 bg-[#154360] relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 40px 40px;"></div>
  <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-[#5dade2]/10 blur-3xl pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-[#e74c3c]/10 blur-3xl pointer-events-none"></div>

  <div class="container mx-auto px-4 md:px-8 relative z-10">

    <!-- Section Label -->
    <div class="flex items-center gap-3 mb-12 justify-center">
      <div class="w-12 h-px bg-[#5dade2]/40"></div>
      <span class="text-[#5dade2] font-black text-xs tracking-[0.4em]">
        {lang === 'tr' ? 'ERİŞİLEBİLİRLİK' : 'AVAILABILITY'}
      </span>
      <div class="w-12 h-px bg-[#5dade2]/40"></div>
    </div>

    <div class="flex flex-col lg:flex-row items-center justify-between gap-16 max-w-5xl mx-auto">

      <!-- Left: Title -->
      <div class="text-center lg:text-left">
        <h2 class="text-4xl md:text-5xl font-sans font-black text-white tracking-tighter leading-tight mb-4">
          {lang === 'tr' ? (
            <>Çalışma <span class="text-[#5dade2]">Saatlerimiz</span></>
          ) : (
            <>Working <span class="text-[#5dade2]">Hours</span></>
          )}
        </h2>
        <p class="text-slate-400 text-lg font-medium max-w-sm">
          {lang === 'tr'
            ? 'Mesai saatleri içinde uzman ekibimize ulaşabilirsiniz.'
            : 'You can reach our expert team during business hours.'}
        </p>
      </div>

      <!-- Right: Hours cards -->
      <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto">

        <!-- Weekdays -->
        <div class="group relative flex-1 lg:flex-none bg-white/5 border border-white/10 rounded-[32px] p-8 hover:bg-white/10 hover:border-[#5dade2]/30 transition-all duration-500 min-w-[220px]">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-[#5dade2]/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-[#5dade2]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <span class="text-[#5dade2] font-black text-xs tracking-widest">
              {lang === 'tr' ? 'HAFTA İÇİ' : 'WEEKDAYS'}
            </span>
          </div>
          <p class="text-white font-black text-3xl tracking-tight leading-none mb-2">08:00 – 18:00</p>
          <p class="text-slate-400 text-sm font-medium">
            {lang === 'tr' ? 'Pazartesi – Cuma' : 'Monday – Friday'}
          </p>
          <!-- Open status indicator -->
          <div class="mt-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-emerald-400 text-xs font-black tracking-wider">
              {lang === 'tr' ? 'AKTİF' : 'ACTIVE'}
            </span>
          </div>
        </div>

        <!-- Weekend -->
        <div class="group relative flex-1 lg:flex-none bg-white/5 border border-white/10 rounded-[32px] p-8 hover:bg-white/10 hover:border-white/20 transition-all duration-500 min-w-[220px]">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
            </div>
            <span class="text-slate-400 font-black text-xs tracking-widest">
              {lang === 'tr' ? 'HAFTA SONU' : 'WEEKEND'}
            </span>
          </div>
          <p class="text-slate-300 font-black text-3xl tracking-tight leading-none mb-2">
            {lang === 'tr' ? 'Kapalı' : 'Closed'}
          </p>
          <p class="text-slate-500 text-sm font-medium">
            {lang === 'tr' ? 'Cumartesi – Pazar' : 'Saturday – Sunday'}
          </p>
          <div class="mt-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-slate-600"></span>
            <span class="text-slate-500 text-xs font-black tracking-wider">
              {lang === 'tr' ? 'KAPALI' : 'CLOSED'}
            </span>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom CTA strip -->
    <div class="mt-16 pt-10 border-t border-white/10 flex flex-col sm:flex-row items-center justify-center gap-6 text-center">
      <p class="text-slate-400 text-sm font-medium">
        {lang === 'tr'
          ? 'Acil destek için WhatsApp üzerinden bize yazabilirsiniz.'
          : 'For urgent support, you can reach us via WhatsApp.'}
      </p>
      <a
        href="https://wa.me/905421826855"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[#25D366] text-white px-6 py-3 rounded-full font-black text-xs tracking-wider hover:bg-[#1ebe5d] transition-all hover:shadow-lg hover:shadow-[#25D366]/30 hover:-translate-y-0.5"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

  </div>
</section>
