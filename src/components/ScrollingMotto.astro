---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-20 bg-[#0b1a2b] overflow-hidden border-y border-white/5 relative group">
  <!-- Subtle Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-r from-[#5dade2]/5 via-transparent to-[#5dade2]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
  
  <div class="flex whitespace-nowrap animate-scroll-slower">
    {[1, 2, 3, 4].map(() => (
      <div class="flex items-center gap-12 px-6">
        <span class="text-4xl md:text-6xl lg:text-8xl font-black text-white/5 tracking-tighter uppercase select-none transition-colors duration-700 group-hover:text-white/10" style="font-family: var(--font-motto);">
          {t('hero.motto2')}
        </span>
        <div class="w-2 h-2 rounded-full bg-[#5dade2]/20 group-hover:bg-[#5dade2]/40 transition-colors"></div>
      </div>
    ))}
  </div>
</section>

<style>
  @keyframes scroll-slower {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .animate-scroll-slower {
    animation: scroll-slower 30s linear infinite;
  }
  
  @media (max-width: 768px) {
    .animate-scroll-slower {
      animation: scroll-slower 20s linear infinite;
    }
  }
</style>
