---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navItems = [
  { label: t('nav.home'), href: `${import.meta.env.BASE_URL}${lang}/` },
  { label: t('nav.about'), href: '#about' },
  { label: t('nav.services'), href: '#services' },
  { label: t('nav.products'), href: '#products' },
  { label: t('nav.projects'), href: '#projects' },
  { label: t('nav.contact'), href: '#contact' },
];
---

<header class="fixed w-full z-50 bg-white/90 backdrop-blur-xl border-b border-slate-100 transition-all duration-300">
  <div class="container mx-auto px-4 md:px-8 h-28 flex items-center justify-between">
    <!-- Logo -->
    <a href={`${import.meta.env.BASE_URL}${lang}/`} class="flex items-center gap-3 group relative">
      <img src={`${import.meta.env.BASE_URL}logo.png`} alt="Luvi Bilişim" class="h-16 w-auto object-contain transition-all duration-500 group-hover:scale-105" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-12">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class="text-[#2c3e50]/80 font-sans text-[13px] font-black tracking-[0.3em] uppercase hover:text-[#154360] transition-all duration-300 relative group"
        >
          {item.label}
          <span class="absolute -bottom-3 left-0 w-0 h-[2px] bg-[#154360] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Language Switcher -->
    <div class="flex items-center gap-4">
      <div class="flex items-center bg-slate-50 border border-slate-100 rounded-full px-1 py-1">
        {Object.entries(languages).map(([l, label]) => (
          <a
            href={`${import.meta.env.BASE_URL}${l}/`}
            class={`px-3 py-1 rounded-full text-xs font-bold uppercase transition-all ${
              lang === l 
                ? 'bg-[#154360] text-white shadow-sm' 
                : 'text-[#2c3e50]/60 hover:text-[#154360]'
            }`}
          >
            {l}
          </a>
        ))}
      </div>
      
      <!-- Mobile Toggle -->
      <button id="menu-toggle" class="lg:hidden text-[#154360] p-2 hover:bg-slate-50 rounded-lg transition-colors" aria-label="Toggle Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="menu-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-[#154360] z-[9999] flex flex-col items-center justify-center gap-12 translate-x-full transition-transform duration-500 lg:hidden px-6">
    <button id="menu-close" class="absolute top-8 right-8 text-white p-2 hover:bg-white/10 rounded-2xl transition-colors" aria-label="Close Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    
    <div class="flex flex-col items-center gap-10">
      {navItems.map((item) => (
        <a 
          href={item.href} 
          class="text-4xl text-white font-heading font-black tracking-widest uppercase hover:text-[#5dade2] transition-colors mobile-link block"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="mt-12 flex items-center bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-2 py-2">
      {Object.entries(languages).map(([l, _]) => (
        <a
          href={`${import.meta.env.BASE_URL}${l}/`}
          class={`px-8 py-3 rounded-full text-base font-bold uppercase transition-all ${
            lang === l 
              ? 'bg-white text-[#154360] shadow-xl' 
              : 'text-white/60 hover:text-white'
          }`}
        >
          {l}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
