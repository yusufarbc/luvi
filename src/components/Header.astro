---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch items for dropdowns
const allServices = await getCollection('services', ({ data }) => data.lang === lang);
const sortedServices = allServices.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const allProducts = await getCollection('products', ({ data }) => data.lang === lang);
const sortedProducts = allProducts.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

const navItems = [
  { label: t('nav.home'), href: `${import.meta.env.BASE_URL}${lang}/` },
  { label: t('nav.about'), href: `${import.meta.env.BASE_URL}${lang}/#about-us` },
  { 
    label: t('nav.services'), 
    href: '#', 
    hasDropdown: true, 
    items: sortedServices.map(s => {
      // Robust slug: extract folder from 'folder/lang' or 'folder/lang.md' etc.
      const slug = s.id.includes('/') ? s.id.split('/')[0] : s.id.replace('.md', '');
      return {
        label: s.data.title,
        href: `${import.meta.env.BASE_URL}${lang}/services/${slug}`
      };
    })
  },
  { 
    label: t('nav.products'), 
    href: '#', 
    hasDropdown: true,
    items: sortedProducts.map(p => {
      const slug = p.id.split('/').pop()?.replace('.md', '');
      return {
        label: p.data.title,
        href: `${import.meta.env.BASE_URL}${lang}/products/${slug}`
      };
    })
  },
];

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<header id="main-header" class="fixed top-0 w-full z-50 transition-all duration-300">
  <div class="w-full flex items-center justify-between h-20 md:h-24 px-4 md:px-12 border-b border-white/10 transition-all duration-300" id="header-inner">
      
      <!-- Logo Section -->
      <a href={`${base}/${lang}/`} class="flex items-center gap-4 group">
        <img src={`${base}/logo.png`} alt="Luvi Bilişim" class="h-14 md:h-18 w-auto object-contain transition-transform duration-500 group-hover:scale-105 brightness-0 invert" id="header-logo" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8 xl:gap-12 text-white">
        {navItems.map((item) => (
          <div class="relative group flex items-center">
            {item.hasDropdown ? (
               <span class="font-sans text-[13px] font-semibold tracking-widest cursor-default transition-all duration-300 relative flex items-center gap-1 group-hover:text-white">
                {item.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                </svg>
                <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-white transition-all duration-500 group-hover:w-full rounded-full"></span>
              </span>
            ) : (
              <a 
                href={item.href} 
                class="font-sans text-[13px] font-semibold tracking-widest hover:text-white transition-all duration-300 relative"
              >
                {item.label}
                <span class="absolute -bottom-2 left-0 w-0 h-[2px] bg-white transition-all duration-500 group-hover:w-full rounded-full"></span>
              </a>
            )}


            {item.hasDropdown && (
              <div class="absolute top-[calc(100%-8px)] left-1/2 -translate-x-1/2 w-64 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-500 transform translate-y-4 group-hover:translate-y-0 z-50">
                <div class="bg-[#0b1a2b]/95 backdrop-blur-2xl border border-white/10 p-4 rounded-3xl shadow-2xl shadow-black/40">
                  {item.items?.map(subItem => (
                    <a 
                      href={subItem.href}
                      class="block px-6 py-3 text-white text-[11px] font-black  tracking-wider hover:bg-white/10 hover:text-[#5dade2] rounded-xl transition-all"
                    >
                      {subItem.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </nav>

      <!-- Action Area -->
      <div class="flex items-center gap-4 md:gap-8">
        <!-- Language Switcher -->
        <div class="hidden md:flex items-center bg-white/5 border border-white/10 rounded-2xl p-1 shadow-inner">
          {Object.entries(languages).map(([l, _]) => (
            <a
              href={`${base}/${l}/`}
              class={`px-3 py-1.5 rounded-xl text-[10px] font-black  transition-all duration-500 ${
                lang === l 
                  ? 'bg-white/10 text-white shadow-lg scale-105' 
                  : 'text-white/40 hover:text-white hover:bg-white/5'
              }`}
            >
              {l}
            </a>
          ))}
        </div>

        <!-- Contact CTA -->
        <a 
          href={`${base}/${lang}/#contact-form`}
          class="hidden md:flex px-8 py-3 bg-[#e74c3c] text-white rounded-xl font-motto text-xs font-black tracking-widest hover:bg-white hover:text-[#e74c3c] hover:shadow-[0_10px_30px_rgba(231,76,60,0.3)] transition-all duration-500 active:scale-95"
        >
          {t('nav.contact')}
        </a>

        <!-- Mobile Toggle -->
        <button id="menu-toggle" class="lg:hidden p-3 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-colors group" aria-label="Toggle Menu">
          <div class="w-6 h-5 relative flex flex-col justify-between">
            <span class="w-full h-0.5 bg-white rounded-full transition-all group-hover:w-1/2"></span>
            <span class="w-full h-0.5 bg-white rounded-full transition-all"></span>
            <span class="w-full h-0.5 bg-white rounded-full transition-all group-hover:w-3/4"></span>
          </div>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-[#0b1a2b]/98 backdrop-blur-2xl z-[9999] flex flex-col items-center justify-start translate-y-full opacity-0 transition-all duration-700 lg:hidden px-6 overflow-y-auto pt-32 pb-12">
    <div class="absolute top-10 right-10">
      <button id="menu-close" class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center text-white border border-white/10 hover:bg-white/10 transition-colors" aria-label="Close Menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <nav class="flex flex-col items-center gap-6 w-full max-w-sm">
      {navItems.map((item, index) => (
        <div class="w-full flex flex-col items-center transform translate-y-8 opacity-0 mobile-link" style={`transition-delay: ${index * 100}ms`}>
          {item.hasDropdown ? (
            <div class="w-full flex flex-col items-center">
              <button 
                class="text-3xl text-white font-heading font-black tracking-tighter  mb-2 flex items-center gap-3 mobile-dropdown-toggle w-full justify-center"
                data-target={`dropdown-${index}`}
              >
                {item.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div id={`dropdown-${index}`} class="hidden flex flex-col items-center gap-4 mt-4 py-4 w-full bg-white/5 rounded-3xl animate-fadeIn">
                 {item.items?.map(subItem => (
                  <a href={subItem.href} class="text-white font-black text-base  tracking-widest hover:text-white/80 transition-colors">{subItem.label}</a>
                 ))}
              </div>
            </div>
          ) : (
            <a 
              href={item.href} 
              class="text-3xl text-white font-heading font-black tracking-tighter  hover:text-[#5dade2] transition-all w-full text-center"
            >
              {item.label}
            </a>
          )}
        </div>
      ))}
      <a 
        href={`${base}/${lang}/#contact`}
        class="mt-12 w-full text-center py-5 bg-[#5dade2] text-white rounded-2xl text-xl font-heading font-black tracking-widest  shadow-2xl transition-all mobile-link transform translate-y-8 opacity-0"
        style={`transition-delay: ${navItems.length * 120}ms`}
      >
        {t('nav.contact')}
      </a>
    </nav>

    <!-- Language Selector -->
    <div class="mt-12 flex items-center bg-white/5 border border-white/10 rounded-full px-2 py-2">
      {Object.entries(languages).map(([l, _]) => (
        <a
          href={`${base}/${l}/`}
          class={`px-10 py-3 rounded-full text-base font-bold  transition-all ${
            lang === l 
              ? 'bg-white text-[#154360]' 
              : 'text-white/40 hover:text-white'
          }`}
        >
          {l}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  const headerInner = document.getElementById('header-inner');
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      headerInner.classList.add('bg-[#0b1a2b]', 'shadow-sm', 'border-white/10');
      headerInner.classList.remove('bg-transparent', 'border-white/10');
      headerInner.querySelectorAll('nav a, nav span').forEach(el => {
        el.classList.add('text-white');
      });
      document.getElementById('header-logo').classList.add('brightness-0', 'invert');
    } else {
      headerInner.classList.remove('bg-[#0b1a2b]', 'shadow-sm', 'border-white/10');
      headerInner.classList.add('bg-transparent', 'border-white/10');
      headerInner.querySelectorAll('nav a, nav span').forEach(el => {
        el.classList.add('text-white');
      });
      document.getElementById('header-logo').classList.add('brightness-0', 'invert');
    }
  });

  function openMenu() {
    mobileMenu.classList.remove('translate-y-full', 'opacity-0');
    document.body.style.overflow = 'hidden';
    setTimeout(() => {
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-8', 'opacity-0');
        });
    }, 100);
  }

  function closeMenu() {
    mobileMenu.classList.add('translate-y-full', 'opacity-0');
    document.body.style.overflow = '';
    mobileLinks.forEach(link => {
      link.classList.add('translate-y-8', 'opacity-0');
    });
    // Reset mobile dropdowns
    document.querySelectorAll('[id^="dropdown-"]').forEach(d => {
        d.classList.add('hidden');
    });
     document.querySelectorAll('.mobile-dropdown-toggle svg').forEach(s => {
        s.classList.remove('rotate-180');
    });
  }

  menuToggle?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  
  mobileLinks.forEach(link => {
    if (!link.querySelector('.mobile-dropdown-toggle')) {
        link.addEventListener('click', closeMenu);
    }
  });

  // Mobile Dropdown Handling
  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = toggle.getAttribute('data-target');
        const target = document.getElementById(targetId);
        const icon = toggle.querySelector('svg');
        
        const isHidden = target.classList.contains('hidden');
        
        // Hide others
        document.querySelectorAll('[id^="dropdown-"]').forEach(d => {
            if (d.id !== targetId) d.classList.add('hidden');
        });
        document.querySelectorAll('.mobile-dropdown-toggle svg').forEach(s => {
            if (s !== icon) s.classList.remove('rotate-180');
        });

        if (isHidden) {
            target.classList.remove('hidden');
            icon.classList.add('rotate-180');
        } else {
            target.classList.add('hidden');
            icon.classList.remove('rotate-180');
        }
    });
  });
</script>

<style>
  .mobile-link {
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
</style>
