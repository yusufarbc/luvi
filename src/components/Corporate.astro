---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="py-32 bg-[#050b14] relative overflow-hidden">
  <div class="container mx-auto px-4 md:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      <!-- Image/Visual Side -->
      <div class="w-full lg:w-1/2 relative">
        <div class="aspect-square rounded-3xl overflow-hidden border border-[#c9a84c]/20 relative group">
          <div class="absolute inset-0 bg-gradient-to-t from-[#0a1628] via-transparent to-transparent z-10"></div>
          <div class="bg-[#0a1628] w-full h-full flex items-center justify-center">
            <span class="text-[#c9a84c] text-[120px] font-serif opacity-20 group-hover:opacity-40 transition-opacity duration-700">L</span>
          </div>
          <!-- Decorative bits -->
          <div class="absolute top-4 left-4 w-12 h-px bg-[#c9a84c]/50"></div>
          <div class="absolute top-4 left-4 h-12 w-px bg-[#c9a84c]/50"></div>
          <div class="absolute bottom-4 right-4 w-12 h-px bg-[#c9a84c]/50"></div>
          <div class="absolute bottom-4 right-4 h-12 w-px bg-[#c9a84c]/50"></div>
        </div>
        <!-- Floating Badge -->
        <div class="absolute -bottom-6 -right-6 bg-[#c9a84c] text-[#0a1628] px-8 py-4 rounded-xl font-sans font-bold shadow-2xl animate-float">
          EST. 2024
        </div>
      </div>

      <!-- Text Side -->
      <div class="w-full lg:w-1/2">
        <h2 class="text-[#c9a84c] font-sans font-bold tracking-[0.4em] uppercase text-sm mb-6">
          {t('about.title')}
        </h2>
        <h3 class="text-4xl md:text-5xl lg:text-6xl font-serif text-white mb-10 leading-tight">
          Anadolu'nun Işığı <br/> <span class="text-[#c9a84c]">İzmir'den</span> Dünyaya.
        </h3>
        <p class="text-white/70 font-sans text-lg leading-relaxed mb-10 text-justify">
          {t('about.text')}
        </p>
        
        <div class="grid grid-cols-2 gap-8">
          <div class="p-6 rounded-2xl bg-[#0a1628] border border-[#c9a84c]/10">
            <p class="text-white font-serif text-3xl mb-2">İzmir</p>
            <p class="text-[#c9a84c] text-xs uppercase tracking-widest">Teknopark Merkezi</p>
          </div>
          <div class="p-6 rounded-2xl bg-[#0a1628] border border-[#c9a84c]/10">
            <p class="text-white font-serif text-3xl mb-2">100%</p>
            <p class="text-[#c9a84c] text-xs uppercase tracking-widest">Yerli İnovasyon</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
