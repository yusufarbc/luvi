---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const aboutEntry = await getEntry('corporate', lang);
const { Content } = await render(aboutEntry);
---

<section id="about" class="py-32 bg-[#050b14] relative overflow-hidden">
  <div class="container mx-auto px-4 md:px-8 max-w-7xl">
    <div class="flex flex-col lg:flex-row items-start gap-16 lg:gap-24">
      <!-- Visual Side (Stays Sticky on Desktop) -->
      <div class="w-full lg:w-5/12 lg:sticky lg:top-32">
        <div class="aspect-[4/5] rounded-[40px] overflow-hidden border border-[#c9a84c]/20 relative group bg-[#0a1628]">
          <div class="absolute inset-0 bg-gradient-to-t from-[#050b14] via-transparent to-transparent z-10"></div>
          <div class="w-full h-full flex flex-col items-center justify-center p-12 text-center">
             <span class="text-[#c9a84c] text-[180px] font-serif opacity-10 group-hover:opacity-20 transition-all duration-1000 transform group-hover:scale-110">L</span>
             <div class="relative z-20">
                <h4 class="text-white font-serif text-2xl mb-2">Luvi Bilişim</h4>
                <p class="text-[#c9a84c] text-xs uppercase tracking-[0.3em] opacity-70">Işık İnsanları</p>
             </div>
          </div>
          <!-- Corner Accents -->
          <div class="absolute top-8 left-8 w-16 h-px bg-[#c9a84c]/30"></div>
          <div class="absolute top-8 left-8 h-16 w-px bg-[#c9a84c]/30"></div>
          <div class="absolute bottom-8 right-8 w-16 h-px bg-[#c9a84c]/30"></div>
          <div class="absolute bottom-8 right-8 h-16 w-px bg-[#c9a84c]/30"></div>
        </div>
        
        <!-- Stats Row -->
        <div class="grid grid-cols-2 gap-4 mt-8">
          <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-sm">
            <p class="text-white font-serif text-4xl mb-1">İzmir</p>
            <p class="text-[#c9a84c] text-[10px] uppercase tracking-[0.2em] font-bold">Teknopark Merkezi</p>
          </div>
          <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-sm">
            <p class="text-white font-serif text-4xl mb-1">100%</p>
            <p class="text-[#c9a84c] text-[10px] uppercase tracking-[0.2em] font-bold">Yerli İnovasyon</p>
          </div>
        </div>
      </div>

      <!-- Text Side (Long Content) -->
      <div class="w-full lg:w-7/12 prose prose-invert prose-gold max-w-none">
        <h2 class="text-[#c9a84c] font-sans font-bold tracking-[0.5em] uppercase text-xs mb-8">
          {t('about.title')}
        </h2>
        <div class="about-content">
          <Content />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .about-content h1 {
    @apply text-4xl md:text-5xl lg:text-6xl font-serif text-white mb-12 leading-tight;
  }
  .about-content h2 {
    @apply text-2xl md:text-3xl font-serif text-[#c9a84c] mt-16 mb-8;
  }
  .about-content p {
    @apply text-white/70 font-sans text-lg leading-[1.8] mb-8 text-justify;
  }
  .about-content ul {
    @apply space-y-6 my-12;
  }
  .about-content li {
    @apply text-white/80 font-sans text-lg pl-4 border-l-2 border-[#c9a84c]/30;
  }
  .about-content li strong {
    @apply text-[#c9a84c] font-bold block mb-1;
  }
  .about-content hr {
    @apply border-white/10 my-16;
  }
</style>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
