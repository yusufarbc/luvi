---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const aboutEntry = await getEntry('corporate', lang);
const { Content } = await render(aboutEntry);
---

<section id="about" class="py-32 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 md:px-8 max-w-7xl">
    <div class="flex flex-col lg:flex-row items-start gap-16 lg:gap-24">
      <!-- Visual Side (Stays Sticky on Desktop) -->
      <div class="w-full lg:w-5/12 lg:sticky lg:top-32">
        <div class="aspect-[4/5] rounded-[40px] overflow-hidden border border-slate-100 relative group bg-slate-50 shadow-inner">
          <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-transparent to-transparent z-10"></div>
          <div class="w-full h-full flex flex-col items-center justify-center p-12 text-center">
             <span class="text-[#0f345a] text-[180px] font-sans font-black opacity-[0.03] group-hover:opacity-[0.05] transition-all duration-1000 transform group-hover:scale-110 select-none">L</span>
             <div class="relative z-20">
                <h4 class="text-[#0f345a] font-sans font-black text-3xl mb-2 tracking-tight">Luvi Bilişim</h4>
                <p class="text-blue-600 text-xs font-bold uppercase tracking-[0.3em] opacity-80">Işık İnsanları</p>
             </div>
          </div>
          <!-- Corner Accents -->
          <div class="absolute top-8 left-8 w-16 h-px bg-blue-500/20"></div>
          <div class="absolute top-8 left-8 h-16 w-px bg-blue-500/20"></div>
          <div class="absolute bottom-8 right-8 w-16 h-px bg-[#ac853c]/20"></div>
          <div class="absolute bottom-8 right-8 h-16 w-px bg-[#ac853c]/20"></div>
        </div>
        
        <!-- Stats Row -->
        <div class="grid grid-cols-2 gap-4 mt-8">
          <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 shadow-sm transition-all hover:shadow-md hover:border-blue-100">
            <p class="text-[#0f345a] font-sans font-black text-4xl mb-1 tracking-tight">İzmir</p>
            <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-bold">Teknopark Merkezi</p>
          </div>
          <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 shadow-sm transition-all hover:shadow-md hover:border-blue-100">
            <p class="text-blue-600 font-sans font-black text-4xl mb-1 tracking-tight">100%</p>
            <p class="text-slate-500 text-[10px] uppercase tracking-[0.2em] font-bold">Yerli İnovasyon</p>
          </div>
        </div>
      </div>

      <!-- Text Side (Long Content) -->
      <div class="w-full lg:w-7/12 prose prose-slate prose-lg max-w-none">
        <h2 class="text-blue-600 font-sans font-black tracking-[0.4em] uppercase text-xs mb-8">
          {t('about.title')}
        </h2>
        <div class="about-content">
          <Content />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @reference "../styles/global.css";
  .about-content h1 {
    @apply text-4xl md:text-5xl lg:text-7xl font-sans font-black text-[#0f345a] mb-12 leading-[1.1] tracking-tight;
  }
  .about-content h2 {
    @apply text-2xl md:text-3xl font-sans font-bold text-[#ac853c] mt-16 mb-8 tracking-tight;
  }
  .about-content p {
    @apply text-slate-600 font-sans text-lg md:text-xl leading-[1.8] mb-8 text-justify;
  }
  .about-content ul {
    @apply space-y-6 my-12;
  }
  .about-content li {
    @apply text-slate-700 font-sans text-lg pl-6 border-l-4 border-blue-500/20 hover:border-blue-500 transition-colors;
  }
  .about-content li strong {
    @apply text-[#0f345a] font-extrabold block mb-1;
  }
  .about-content hr {
    @apply border-slate-100 my-16;
  }
</style>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
