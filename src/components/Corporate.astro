---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getEntry, render } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const aboutEntry = await getEntry('corporate', lang);
const { Content } = await render(aboutEntry);
---

<section id="about" class="py-32 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 md:px-8 max-w-7xl">
    <div class="flex flex-col lg:flex-row items-start gap-16 lg:gap-24">
      <!-- Visual Side (Stays Sticky on Desktop) -->
      <div class="w-full lg:w-5/12 lg:sticky lg:top-32">
        <div class="aspect-[4/5] rounded-[48px] overflow-hidden border border-slate-100 relative group bg-[#154360] shadow-sm hover:shadow-2xl transition-all duration-700">
          <div class="absolute inset-0 z-0">
            <img 
              src={`${import.meta.env.BASE_URL}building.webp`} 
              alt="Luvi Bilişim Visual" 
              class="w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity duration-1000 group-hover:scale-110 transition-transform duration-[2000ms]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#154360] via-transparent to-transparent"></div>
          </div>
          <div class="w-full h-full flex flex-col items-center justify-end p-16 text-center relative z-10">
             <div class="relative">
                <h4 class="text-white font-heading font-black text-4xl mb-3 tracking-tighter">Luvi Bilişim</h4>
             </div>
          </div>
          <!-- Corner Accents -->
          <div class="absolute top-10 left-10 w-12 h-px bg-white/20"></div>
          <div class="absolute top-10 left-10 h-12 w-px bg-white/20"></div>
          <div class="absolute bottom-10 right-10 w-12 h-px bg-[#5dade2]/30"></div>
          <div class="absolute bottom-10 right-10 h-12 w-px bg-[#5dade2]/30"></div>
        </div>
      </div>

      <!-- Text Side (Long Content) -->
      <div class="w-full lg:w-7/12 prose prose-slate prose-lg max-w-none">
        <h2 class="text-4xl md:text-5xl lg:text-7xl font-heading font-black text-[#154360] mb-12 leading-[1.1] tracking-tighter">
          {t('about.title')}
        </h2>
        <div class="about-content">
          <Content />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @reference "../styles/global.css";
  .about-content h1 {
    @apply text-4xl md:text-5xl lg:text-7xl font-heading font-black text-[#154360] mb-12 leading-[1.1] tracking-tighter;
  }
  .about-content h2 {
    @apply text-2xl md:text-4xl font-heading font-black text-[#154360] mt-16 mb-8 tracking-tighter;
  }
  .about-content p {
    @apply text-slate-500 font-sans text-lg md:text-xl leading-[1.8] mb-8 text-justify;
  }
  .about-content ul {
    @apply space-y-6 my-12;
  }
  .about-content li {
    @apply text-slate-500 font-sans text-lg pl-8 border-l-2 border-[#5dade2]/20 hover:border-[#5dade2] transition-colors;
  }
  .about-content li strong {
    @apply text-[#154360] font-black block mb-1;
  }
  .about-content hr {
    @apply border-slate-100 my-16;
  }
</style>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>
