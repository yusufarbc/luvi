---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<section id="about" class="relative h-[80vh] w-full flex items-center justify-center overflow-hidden bg-black">
  <!-- Video Background -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <video 
      id="corp-video"
      autoplay 
      muted 
      playsinline 
      webkit-playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-50 transition-opacity duration-1000"
    >
      <source src={`${base}/banner/1.webm`} type="video/webm" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black opacity-80"></div>
  </div>

  <script is:inline>
    // Robust video playlist logic
    const corpVideo = document.getElementById('corp-video');
    const corpPlaylist = ['banner/1.webm', 'banner/2.webm', 'banner/3.webm'];
    let corpCurrentIndex = 0;

    // Use a helper to resolve the base path
    const getBaseUrl = () => {
      const b = document.documentElement.getAttribute('data-base') || '';
      return b.endsWith('/') ? b : b + '/';
    };

    function playNextCorpVideo() {
      if (!corpVideo) return;
      
      corpVideo.style.opacity = '0';
      
      setTimeout(() => {
        corpCurrentIndex = (corpCurrentIndex + 1) % corpPlaylist.length;
        const newSrc = '/' + corpPlaylist[corpCurrentIndex];
        // For development, we want to ensure it works relatively
        // If it's on a base path, we need to prefix it.
        // We can just use the absolute path from root if it's served from root.
        corpVideo.src = newSrc;
        
        corpVideo.load();
        corpVideo.play().then(() => { 
          corpVideo.style.opacity = '0.5'; 
        }).catch(err => {
          console.log("Video transition failed, trying again...", err);
          corpVideo.muted = true;
          corpVideo.play();
        });
      }, 1000);
    }

    if (corpVideo) {
      corpVideo.addEventListener('ended', playNextCorpVideo);
    }
  </script>

  <div class="container mx-auto px-4 md:px-8 relative z-10 flex flex-col items-start text-left">
    <div class="max-w-4xl">
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-heading font-black tracking-tighter mb-12 drop-shadow-2xl animate-fade-in text-white">
        {t('corporate.glance')}
      </h2>
      
      <div class="flex items-center gap-12 group">
        <a 
          href={`#about-us`}
          class="px-12 py-5 border-2 border-white/30 text-white rounded-full font-heading font-black text-lg tracking-widest hover:bg-white hover:text-black hover:border-white transition-all duration-500 transform hover:translate-x-2"
        >
          {t('corporate.button')}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-fade-in {
    animation: fadeIn 1.2s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

