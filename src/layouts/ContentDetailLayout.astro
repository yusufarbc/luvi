---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  frontmatter: any;
  showContactCTA?: boolean;
  galleryImages?: any[];
}

const { frontmatter, showContactCTA = true, galleryImages = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`${frontmatter.title} | Luvi Bilişim`} lang={lang}>
  <Header />
  
  <!-- Progress Bar for long content -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-[#5dade2] z-[101] transition-all duration-300 w-0"></div>

  <main class="pt-32 pb-32 bg-white min-h-screen">
    <div class="container mx-auto px-4 md:px-8 max-w-5xl">
      <!-- Breadcrumbs / Back -->
      <nav class="flex items-center gap-4 text-[#154360] font-sans text-[10px] font-black tracking-[0.3em] mb-12 hover:text-[#5dade2] transition-colors group uppercase">
        <a href={`${base}/${lang}/#${frontmatter.icon ? 'services' : (frontmatter.pubDate ? 'news' : 'products')}`} class="inline-flex items-center gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {t('nav.home')}
        </a>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Sidebar (Hidden on Mobile) -->
        <aside class="hidden lg:flex lg:col-span-3 flex-col gap-12 sticky top-40">
           <div class="flex flex-col gap-6">
              <h4 class="text-[#154360] font-sans font-black text-[11px] tracking-[0.4em] uppercase opacity-40">{lang === 'tr' ? 'BÖLÜMLER' : 'SECTIONS'}</h4>
              <nav id="toc" class="flex flex-col gap-4 border-l-2 border-slate-50 ml-1">
                <!-- TOC items will be injected or hardcoded if needed, but for now just a placeholder for visual style -->
              </nav>
           </div>
        </aside>

        <!-- Main Content Column -->
        <div class="lg:col-span-9">
          <!-- Header -->
          <header class="mb-20">
            {frontmatter.pubDate && (
              <span class="inline-block px-4 py-1.5 bg-slate-50 text-[#5dade2] text-[10px] font-black tracking-widest rounded-full mb-8 uppercase">
                {new Date(frontmatter.pubDate).toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            )}
            
            <div class="flex flex-col gap-6">
              <h1 class="text-4xl md:text-6xl font-heading font-black text-[#154360] leading-[1.1] tracking-tighter">
                {frontmatter.title}
              </h1>
              <div class="h-1.5 w-24 bg-[#5dade2] rounded-full mb-2"></div>
              <p class="text-slate-400 text-xl md:text-2xl font-sans leading-relaxed font-light max-w-3xl">
                {frontmatter.description}
              </p>
            </div>
          </header>

          <!-- Main Cover Image -->
          {frontmatter.image && (
            <div class="mb-24 rounded-[64px] overflow-hidden bg-slate-50 aspect-video shadow-[0_45px_120px_-25px_rgba(21,67,96,0.18)] border border-slate-100 cursor-zoom-in lightbox-trigger group">
               <Image 
                 src={frontmatter.image} 
                 alt={frontmatter.title} 
                 class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
               />
            </div>
          )}
          <!-- Content -->
          <article class="prose-container prose prose-slate prose-xl max-w-none 
            prose-h2:font-heading prose-h2:font-black prose-h2:text-[#154360] prose-h2:text-4xl prose-h2:md:text-5xl prose-h2:mt-32 prose-h2:mb-10 prose-h2:tracking-tight prose-h2:leading-[1.1]
            prose-h3:font-heading prose-h3:font-black prose-h3:text-[#1c5d8e] prose-h3:text-xl prose-h3:md:text-2xl prose-h3:mt-20 prose-h3:mb-6 prose-h3:tracking-tight prose-h3:flex prose-h3:items-center prose-h3:gap-4
            prose-p:text-slate-600 prose-p:text-lg md:prose-p:text-xl prose-p:leading-[1.8] prose-p:mb-10 prose-p:font-normal
            prose-li:text-slate-600 prose-li:text-lg md:prose-li:text-lg prose-li:mb-4 prose-li:leading-relaxed
            prose-strong:text-[#154360] prose-strong:font-bold
            prose-hr:border-slate-100 prose-hr:my-24
            prose-blockquote:border-l-[8px] prose-blockquote:border-[#5dade2] prose-blockquote:pl-10 prose-blockquote:italic prose-blockquote:text-2xl prose-blockquote:text-[#154360] prose-blockquote:bg-slate-50/50 prose-blockquote:py-10 prose-blockquote:pr-8 prose-blockquote:rounded-r-2xl prose-blockquote:my-16
          ">
            <slot />
          </article>

          <!-- Logo at the bottom -->
          {frontmatter.logo && (
            <div class="mt-32 mb-12 flex justify-center border-t border-slate-50 pt-24">
              <img src={`${base}${frontmatter.logo}`} alt={frontmatter.title} class="h-16 md:h-24 w-auto object-contain hover:scale-105 transition-transform duration-700" />
            </div>
          )}

          <!-- Gallery (if any) -->
          {galleryImages.length > 0 && (
            <div class="mt-40">
              <h2 class="text-3xl font-black text-[#154360] mb-16 tracking-tighter flex items-center gap-6">
                 {lang === 'tr' ? 'Görsel Arşivi' : 'Visual Archive'}
                 <div class="h-[2px] flex-1 bg-slate-50"></div>
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {galleryImages.map((img: any) => (
                  <div class="group relative aspect-video rounded-[40px] overflow-hidden bg-slate-50 border border-slate-100 shadow-lg hover:shadow-2xl transition-all duration-700 cursor-zoom-in lightbox-trigger">
                    <Image 
                      src={img} 
                      alt={frontmatter.title} 
                      class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-[#154360]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-[200] bg-[#0b1a2b]/95 backdrop-blur-3xl hidden items-center justify-center p-4 md:p-12 opacity-0 transition-opacity duration-500 cursor-zoom-out">
      <button id="close-lightbox" class="absolute top-10 right-10 w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-white/10 transition-all z-[201]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
      </button>
      <img id="lightbox-img" src="" alt="Large View" class="max-w-full max-h-full object-contain rounded-3xl shadow-[0_50px_150px_-30px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-500 border border-white/5" />
  </div>
</Layout>

<style is:global>
  /* Custom Prose Styling */
  .prose-container h3 {
    position: relative;
  }
  
  .prose-container h3::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    background-color: #5dade2;
    border-radius: 99px;
    margin-top: 0.75rem;
  }

  .prose-container p {
    margin-bottom: 2.5rem !important;
  }

  .prose-container ul {
    margin-top: 2rem !important;
    margin-bottom: 3rem !important;
  }

  .prose-container ul li {
    position: relative;
    padding-left: 2rem;
    list-style: none !important;
  }

  .prose-container ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    width: 10px;
    height: 10px;
    background-color: #5dade2;
    border-radius: 3px;
    transform: rotate(45deg);
  }

  /* Lightbox Logic */
  #lightbox.active {
    display: flex;
    opacity: 1;
  }
  #lightbox.active #lightbox-img {
    transform: scale(1);
  }

  #toc a.active {
    color: #5dade2;
    border-left-color: #5dade2;
    padding-left: 1.5rem;
    font-weight: 800;
  }
</style>

<script is:inline>
  // Progress Bar
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById("progress-bar");
    if (bar) bar.style.width = scrolled + "%";
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const closeBtn = document.getElementById('close-lightbox');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const img = trigger.querySelector('img');
      if (img) {
        lightboxImg.src = img.src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => lightbox.classList.add('active'), 10);
      }
    });
  });

  function closeLightbox() {
    lightbox.classList.remove('active');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }, 500);
  }

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxImg) {
      closeLightbox();
    }
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // Simple TOC Generation
  const article = document.querySelector('article');
  const toc = document.getElementById('toc');
  if (article && toc) {
    const headings = article.querySelectorAll('h2');
    headings.forEach((h, index) => {
      const id = `section-${index}`;
      h.setAttribute('id', id);
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = h.textContent;
      link.className = 'text-slate-400 font-sans text-[11px] font-bold tracking-tight py-2 border-l-2 border-transparent pl-4 hover:text-[#154360] transition-all truncate';
      toc.appendChild(link);
    });
  }
</script>
