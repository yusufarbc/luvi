---
import Layout from './Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const { frontmatter } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`${frontmatter.title} | Luvi Bilişim`}>
  <main class="pt-32 pb-24 bg-[#050b14] min-h-screen">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <!-- Navigation / Back -->
      <a 
        href={`${base}/${lang}/#${frontmatter.icon ? 'services' : 'products'}`} 
        class="inline-flex items-center gap-2 text-[#c9a84c] font-sans text-xs uppercase tracking-[0.3em] mb-12 hover:opacity-70 transition-opacity group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t('nav.home')}
      </a>

      <!-- Header -->
      <header class="mb-16">
        <h1 class="text-4xl md:text-6xl font-serif text-white mb-6 leading-tight">
          {frontmatter.title}
        </h1>
        <p class="text-[#c9a84c] text-lg font-sans tracking-wide opacity-80">
          {frontmatter.description}
        </p>
      </header>

      <!-- Content -->
      <article class="prose prose-invert prose-gold max-w-none 
        prose-h2:font-serif prose-h2:text-[#c9a84c] prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
        prose-p:text-white/70 prose-p:text-lg prose-p:leading-relaxed prose-p:mb-8
        prose-li:text-white/70 prose-li:text-lg prose-li:mb-2
        prose-strong:text-white prose-strong:font-bold
      ">
        <slot />
      </article>

      <!-- Footer CTA -->
      <div class="mt-24 p-12 rounded-[40px] bg-gradient-to-br from-[#1a2533] to-[#0a1628] border border-[#c9a84c]/20 text-center">
        <h3 class="text-2xl font-serif text-white mb-6">{t('nav.contact')}</h3>
        <p class="text-white/60 mb-8 max-w-md mx-auto">
          {frontmatter.title} {lang === 'tr' ? 'hizmetimiz hakkında detaylı bilgi ve teklif almak için bizimle iletişime geçin.' : 'solutions, contact us for detailed information and a quote.'}
        </p>
        <a 
          href="#contact" 
          class="inline-block px-10 py-5 bg-[#c9a84c] text-[#0a1628] rounded-2xl font-sans font-black uppercase tracking-widest hover:bg-white transition-all duration-300"
        >
          {t('nav.contact')}
        </a>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Custom prose styling to match the premium theme */
  .prose-gold :where(h2):not(:where([class~="not-prose"] *)) {
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    padding-bottom: 0.5rem;
  }
</style>
