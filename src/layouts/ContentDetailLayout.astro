---
import Layout from './Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  frontmatter: any;
  showContactCTA?: boolean;
  galleryImages?: any[];
  otherProducts?: any[];
  otherServices?: any[];
}

const { frontmatter, showContactCTA = true, galleryImages = [], otherProducts = [], otherServices = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title={`${frontmatter.title} | Luvi Bilişim`} lang={lang}>
  
  <!-- Progress Bar for long content -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-[#5dade2] z-[101] transition-all duration-300 w-0"></div>

  <main class="pt-14 pb-32 bg-slate-50 min-h-screen">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">


      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Sidebar (Hidden on Mobile) -->
        <aside class="hidden lg:flex lg:col-span-3 flex-col gap-12 sticky top-40">
           <div class="flex flex-col gap-6">
              <h4 class="text-[#154360] font-sans font-black text-[11px] tracking-[0.4em] uppercase opacity-40">{lang === 'tr' ? 'BÖLÜMLER' : 'SECTIONS'}</h4>
              <nav id="toc" class="flex flex-col gap-1 border-l-2 border-slate-100 ml-1">
                <!-- TOC items will be injected as accordions -->
              </nav>
           </div>
        </aside>

        <!-- Main Content Column -->
        <div class="lg:col-span-9">
          <div class="bg-white rounded-[48px] p-8 md:p-16 lg:p-24 shadow-[0_20px_50px_rgba(21,67,96,0.05)] border border-slate-100">
            <!-- Header -->
            <header class="mb-20">
              {frontmatter.pubDate && (
                <span class="inline-block px-4 py-1.5 bg-slate-50 text-[#5dade2] text-[10px] font-black tracking-widest rounded-full mb-8 uppercase">
                  {new Date(frontmatter.pubDate).toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
              )}
              
              {frontmatter.logo ? (
                <!-- Product/Brand page: Logo centered -->
                <div class="flex flex-col items-center text-center gap-8">
                  <div class="flex items-center justify-center py-4 group">
                    <img 
                      src={`${base}${frontmatter.logo}`} 
                      alt={frontmatter.title} 
                      class="h-20 md:h-28 lg:h-32 w-auto object-contain transition-transform duration-700 group-hover:scale-110" 
                    />
                  </div>
                  <div class="h-1.5 w-24 bg-gradient-to-r from-[#5dade2] to-[#154360] rounded-full shadow-[0_4px_10px_rgba(93,173,226,0.3)]"></div>
                  <p class="text-slate-400 text-xl md:text-2xl font-sans leading-relaxed font-light max-w-3xl">
                    {frontmatter.description}
                  </p>
                </div>
              ) : (
                <!-- Service page: Centered Title + Icon for premium consistency -->
                <div class="flex flex-col items-center text-center gap-6">
                  {frontmatter.icon && (
                    <div class="w-20 h-20 rounded-[28px] bg-white shadow-[0_15px_35px_rgba(21,67,96,0.08)] border border-slate-100 flex items-center justify-center group hover:scale-110 transition-all duration-700">
                      <div class="text-[#5dade2] group-hover:text-[#154360] transition-colors duration-500">
                         <div class="w-8 h-8 border-[2.5px] border-current rounded-full flex items-center justify-center">
                            <div class="w-2 h-2 bg-current rounded-full"></div>
                         </div>
                      </div>
                    </div>
                  )}
                  <h1 class="text-3xl md:text-5xl lg:text-6xl font-heading font-black text-[#154360] leading-[1.1] tracking-tighter max-w-4xl">
                    {frontmatter.title}
                  </h1>
                  <div class="h-1.5 w-24 bg-gradient-to-r from-[#5dade2] to-[#154360] rounded-full shadow-[0_4px_10px_rgba(93,173,226,0.3)]"></div>
                  <p class="text-slate-500 text-lg md:text-xl font-sans leading-relaxed font-light max-w-3xl">
                    {frontmatter.description}
                  </p>
                </div>
              )}
            </header>

            <!-- Main Media (YouTube or Image) -->
            {frontmatter.youtubeId ? (
              <div class="mb-24 rounded-[64px] overflow-hidden bg-slate-900 aspect-video shadow-[0_45px_120px_-25px_rgba(21,67,96,0.3)] border border-[#5dade2]/20 relative group">
                <iframe 
                  src={`https://www.youtube.com/embed/${frontmatter.youtubeId}?autoplay=0&rel=0`}
                  title={frontmatter.title}
                  class="absolute inset-0 w-full h-full"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                  allowfullscreen
                ></iframe>
              </div>
            ) : frontmatter.image && (
              <div class="mb-24 rounded-[64px] overflow-hidden bg-slate-50 aspect-video shadow-[0_45px_120px_-25px_rgba(21,67,96,0.18)] border border-slate-100 cursor-zoom-in lightbox-trigger group">
                 <Image 
                   src={frontmatter.image} 
                   alt={frontmatter.title} 
                   class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                 />
              </div>
            )}
            <!-- Content -->
            <!-- Content area with manual styling for premium feel -->
            <article class="premium-luvi-article prose-container max-w-none">
              <slot />
            </article>


          </div>

          <!-- Gallery (if any) - Outside the card for better visual flow -->
          {galleryImages.length > 0 && (
            <div class="mt-40">
              <h2 class="text-3xl font-black text-[#154360] mb-16 tracking-tighter flex items-center gap-6">
                 {lang === 'tr' ? 'Görsel Arşivi' : 'Visual Archive'}
                 <div class="h-[2px] flex-1 bg-slate-200"></div>
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {galleryImages.map((img: any) => (
                  <div class="group relative aspect-video rounded-[40px] overflow-hidden bg-slate-50 border border-slate-100 shadow-lg hover:shadow-2xl transition-all duration-700 cursor-zoom-in lightbox-trigger">
                    <Image 
                      src={img} 
                      alt={frontmatter.title} 
                      class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-[#154360]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Other Products/Services Quick Links (outside grid to prevent overlap) -->
      {(otherProducts.length > 0 || otherServices.length > 0) && (
        <div class="mt-24">
          <div class="border-t border-slate-200 pt-16">
            <div class="flex items-center gap-6 mb-12">
              <h2 class="text-[#154360] font-heading font-black text-2xl md:text-3xl tracking-tight whitespace-nowrap">
                {otherProducts.length > 0
                  ? (lang === 'tr' ? 'Diğer Çözümlerimiz' : 'Our Other Solutions')
                  : (lang === 'tr' ? 'Diğer Hizmetlerimiz' : 'Our Other Services')}
              </h2>
              <div class="h-[2px] flex-1 bg-slate-200"></div>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-4">
              {(otherProducts.length > 0 ? otherProducts : otherServices).map((item: any) => {
                const itemSlug = item.id.split('/').pop()?.replace('.md', '').replace(/\/(tr|en)$/, '').split('/').shift();
                const section = otherProducts.length > 0 ? 'products' : 'services';
                
                // For services, items might not have a logo, so we use their icons if possible, or just text
                return (
                  <a 
                    href={`${base}/${item.data.lang}/${section}/${itemSlug}`}
                    class="group flex flex-col items-center justify-center p-5 bg-white rounded-2xl border border-slate-100 hover:border-[#5dade2]/30 hover:shadow-lg hover:shadow-[#5dade2]/5 transition-all duration-500 text-center"
                    title={item.data.title}
                  >
                    {item.data.logo ? (
                      <img 
                        src={`${base}${item.data.logo}`} 
                        alt={item.data.title} 
                        class="h-8 md:h-10 w-auto object-contain grayscale group-hover:grayscale-0 opacity-50 group-hover:opacity-100 transition-all duration-500 group-hover:scale-110" 
                      />
                    ) : (
                      <div class="flex flex-col items-center gap-2">
                         <div class="text-[#5dade2] group-hover:text-[#154360] font-black text-[10px] uppercase tracking-widest opacity-40 group-hover:opacity-100 transition-all">
                             {item.data.title.split(' ').slice(0, 2).join(' ')}
                         </div>
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      )}
    </div>
    </div>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-[200] bg-[#0b1a2b]/95 backdrop-blur-3xl hidden items-center justify-center p-4 md:p-12 opacity-0 transition-opacity duration-500 cursor-zoom-out">
      <button id="close-lightbox" class="absolute top-10 right-10 w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-white/10 transition-all z-[201]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
      </button>
      <img id="lightbox-img" src="" alt="Large View" class="max-w-full max-h-full object-contain rounded-3xl shadow-[0_50px_150px_-30px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-500 border border-white/5" />
  </div>
</Layout>

<style is:global>
  /* TOC Accordion Styles */
  #toc .toc-item {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #toc .toc-h2-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    font-size: 11px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8; /* slate-400 */
    border-left: 3px solid transparent;
    transition: all 0.3s ease;
    cursor: pointer;
    line-height: 1.2;
    text-decoration: none;
    margin-left: -2px;
  }

  #toc .toc-h2-link:hover {
    color: #154360;
    background: rgba(241, 245, 249, 0.5); /* slate-100 */
  }

  #toc .toc-item.is-active .toc-h2-link {
    color: #154360;
    border-left-color: #5dade2;
    background: linear-gradient(to right, rgba(93, 173, 226, 0.08), transparent);
  }

  #toc .toc-subheadings {
    max-height: 0;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding-left: 0.5rem;
    border-left: 1px solid #f1f5f9;
    margin-left: 1rem;
  }

  #toc .toc-item.is-expanded .toc-subheadings {
    max-height: 1000px; /* Large enough for sub-items */
    margin-bottom: 0.5rem;
  }

  #toc .toc-h3-link {
    padding: 0.6rem 1rem;
    font-size: 10px;
    font-weight: 600;
    color: #64748b; /* slate-500 */
    transition: all 0.2s ease;
    text-decoration: none;
    border-radius: 8px;
    line-height: 1.4;
  }

  #toc .toc-h3-link:hover {
    color: #5dade2;
    padding-left: 1.25rem;
  }

  #toc .toc-h3-link.active {
    color: #5dade2;
    background: rgba(93, 173, 226, 0.04);
  }

  /* Chevron for H2 */
  #toc .chevron {
    width: 10px;
    height: 10px;
    transition: transform 0.4s ease;
    opacity: 0.5;
  }

  #toc .toc-item.is-expanded .chevron {
    transform: rotate(180deg);
  }

  /* Premium Luvi Article Detail Styles */
  .premium-luvi-article {
    --text-primary: #154360;
    --text-body: #475569;
    --accent: #5dade2;
    display: block;
    width: 100%;
  }

  .premium-luvi-article h2 {
    color: #154360 !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 2.75rem !important;
    font-weight: 900 !important;
    line-height: 1.1 !important;
    margin-top: 6rem !important;
    margin-bottom: 2.5rem !important;
    letter-spacing: -0.04em !important;
    position: relative !important;
    padding-left: 3.5rem !important;
    display: block !important;
    border: none !important;
  }

  @media (max-width: 768px) {
    .premium-luvi-article h2 {
      font-size: 2.1rem !important;
      padding-left: 2rem !important;
      margin-top: 4rem !important;
    }
  }

  .premium-luvi-article h2::before {
    content: '' !important;
    position: absolute !important;
    left: 0 !important;
    top: 0 !important;
    bottom: 0 !important;
    width: 10px !important;
    background: linear-gradient(to bottom, #5dade2, #154360) !important;
    border-radius: 4px !important;
  }

  .premium-luvi-article h3 {
    color: #1c5d8e !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 1.85rem !important;
    font-weight: 800 !important;
    margin-top: 4rem !important;
    margin-bottom: 1.5rem !important;
    letter-spacing: -0.02em !important;
    padding: 0.5rem 0 0.5rem 1.5rem !important;
    border-left: 5px solid #5dade2 !important;
    background: linear-gradient(to right, rgba(93, 173, 226, 0.05), transparent) !important;
    line-height: 1.3 !important;
    display: block !important;
    border-radius: 0 12px 12px 0 !important;
  }

  .premium-luvi-article p {
    color: #475569 !important;
    font-size: 1.18rem !important;
    line-height: 1.85 !important;
    margin-bottom: 2rem !important;
    font-weight: 400 !important;
    display: block !important;
  }

  /* First paragraph after h2/h3 special treatment (Motto/Lead) */
  .premium-luvi-article h2 + p,
  .premium-luvi-article h3 + p {
    font-size: 1.4rem !important;
    color: #334155 !important;
    font-weight: 500 !important;
    line-height: 1.6 !important;
    margin-top: -1rem !important;
    margin-bottom: 2.5rem !important;
  }

  /* Special style for strong highlights often used as mottos */
  .premium-luvi-article p > strong:only-child,
  .premium-luvi-article h2 + p > strong,
  .premium-luvi-article h3 + p > strong {
    display: inline-block !important;
    color: #154360 !important;
    font-size: 1.45rem !important;
    font-weight: 900 !important;
    border-bottom: 2.5px solid rgba(93, 173, 226, 0.25) !important;
    padding-bottom: 0.2rem !important;
  }

  .premium-luvi-article ul {
    margin-top: 2rem !important;
    margin-bottom: 3rem !important;
    padding-left: 0.5rem !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 1.25rem !important;
    list-style: none !important;
  }

  .premium-luvi-article ul li {
    position: relative !important;
    padding-left: 3.5rem !important;
    list-style: none !important;
    color: #475569 !important;
    font-size: 1.15rem !important;
    line-height: 1.7 !important;
    display: block !important;
  }

  .premium-luvi-article ul li::before {
    content: '' !important;
    position: absolute !important;
    left: 0 !important;
    top: 0.75rem !important;
    width: 25px !important;
    height: 4px !important;
    background: linear-gradient(to right, #5dade2, #154360) !important;
    border-radius: 99px !important;
  }

  .premium-luvi-article blockquote {
    border-left: 10px solid #5dade2 !important;
    padding: 3.5rem 3rem 3.5rem 5rem !important;
    margin: 5rem 0 !important;
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%) !important;
    border-radius: 0 48px 48px 0 !important;
    font-style: italic !important;
    font-size: 1.85rem !important;
    color: #154360 !important;
    font-family: 'Montserrat', sans-serif !important;
    font-weight: 600 !important;
    line-height: 1.4 !important;
    position: relative !important;
  }

  .premium-luvi-article blockquote::after {
    content: '"' !important;
    position: absolute !important;
    top: 0 !important;
    left: 1.5rem !important;
    font-size: 8rem !important;
    opacity: 0.1 !important;
    color: #154360 !important;
    font-family: serif !important;
  }
  .premium-luvi-article hr {
    height: 1px !important;
    border: none !important;
    background: linear-gradient(to right, transparent, rgba(93, 173, 226, 0.4), transparent) !important;
    margin: 6rem 0 !important;
  }

  /* Offset for fixed navbar */
  h2, h3 {
    scroll-margin-top: 140px;
  }
</style>

<script is:inline>
  // Progress Bar
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById("progress-bar");
    if (bar) bar.style.width = scrolled + "%";
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const closeBtn = document.getElementById('close-lightbox');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const img = trigger.querySelector('img');
      if (img) {
        lightboxImg.src = img.src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => lightbox.classList.add('active'), 10);
      }
    });
  });

  function closeLightbox() {
    lightbox.classList.remove('active');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }, 500);
  }

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxImg) {
      closeLightbox();
    }
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // Advanced Accordion-Style TOC Generation
  const article = document.querySelector('article');
  const toc = document.getElementById('toc');

  if (article && toc) {
    const headings = article.querySelectorAll('h2, h3');
    let currentItem = null;
    let currentSubContainer = null;

    headings.forEach((h, index) => {
      const id = h.id || `section-${index}`;
      h.setAttribute('id', id);

      if (h.tagName === 'H2') {
        const itemWrapper = document.createElement('div');
        itemWrapper.className = 'toc-item';
        
        const h2Link = document.createElement('a');
        h2Link.href = `#${id}`;
        h2Link.className = 'toc-h2-link';
        
        const textSpan = document.createElement('span');
        textSpan.textContent = h.textContent;
        h2Link.appendChild(textSpan);

        // Add chevron icon
        const chevron = document.createElement('div');
        chevron.className = 'chevron';
        chevron.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>';
        h2Link.appendChild(chevron);

        itemWrapper.appendChild(h2Link);
        
        const subheadings = document.createElement('div');
        subheadings.className = 'toc-subheadings';
        itemWrapper.appendChild(subheadings);
        
        toc.appendChild(itemWrapper);
        currentItem = itemWrapper;
        currentSubContainer = subheadings;

        h2Link.addEventListener('click', (e) => {
          // Accordion logic: only one open at a time
          const isExpanded = itemWrapper.classList.contains('is-expanded');
          
          if (!isExpanded) {
            document.querySelectorAll('#toc .toc-item.is-expanded').forEach(item => {
              item.classList.remove('is-expanded');
            });
            itemWrapper.classList.add('is-expanded');
          }
        });
      } else if (h.tagName === 'H3' && currentSubContainer) {
        const h3Link = document.createElement('a');
        h3Link.href = `#${id}`;
        h3Link.textContent = h.textContent;
        h3Link.className = 'toc-h3-link';
        currentSubContainer.appendChild(h3Link);
      }
    });

    // Intersection Observer to highlight active sections and auto-expand
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          const tocLinks = document.querySelectorAll('#toc a');
          const activeLink = Array.from(tocLinks).find(link => link.getAttribute('href') === `#${id}`);
          
          if (activeLink) {
            // Remove active/is-active from everywhere
            document.querySelectorAll('#toc .is-active').forEach(item => item.classList.remove('is-active'));
            document.querySelectorAll('#toc .toc-h3-link.active').forEach(link => link.classList.remove('active'));

            if (activeLink.classList.contains('toc-h2-link')) {
              const item = activeLink.closest('.toc-item');
              item.classList.add('is-active');
              
              // Auto-expand if not already
              if (!item.classList.contains('is-expanded')) {
                 document.querySelectorAll('#toc .toc-item.is-expanded').forEach(el => el.classList.remove('is-expanded'));
                 item.classList.add('is-expanded');
              }
            } else if (activeLink.classList.contains('toc-h3-link')) {
              activeLink.classList.add('active');
              const item = activeLink.closest('.toc-item');
              item.classList.add('is-active');
              
              // Ensure parent is expanded
              if (!item.classList.contains('is-expanded')) {
                 document.querySelectorAll('#toc .toc-item.is-expanded').forEach(el => el.classList.remove('is-expanded'));
                 item.classList.add('is-expanded');
              }
            }
          }
        }
      });
    }, observerOptions);

    headings.forEach(h => observer.observe(h));
  }
</script>
