---
import Layout from './Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const { frontmatter } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`${frontmatter.title} | Luvi Bilişim`} lang={lang}>
  <main class="pt-32 pb-24 bg-white min-h-screen">
    <div class="container mx-auto px-4 md:px-8 max-w-4xl">
      <!-- Navigation / Back -->
      <a 
        href={`${base}/${lang}/#${frontmatter.icon ? 'services' : 'products'}`} 
        class="inline-flex items-center gap-3 text-blue-600 font-sans text-xs font-bold uppercase tracking-[0.2em] mb-12 hover:text-[#0f345a] transition-colors group"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {t('nav.home')}
      </a>

      <!-- Header -->
      <header class="mb-16">
        <h1 class="text-4xl md:text-7xl font-sans font-black text-[#0f345a] mb-6 leading-tight tracking-tight">
          {frontmatter.title}
        </h1>
        <p class="text-slate-500 text-xl font-sans leading-relaxed">
          {frontmatter.description}
        </p>
      </header>

      <!-- Content -->
      <article class="prose prose-slate prose-lg max-w-none 
        prose-h2:font-sans prose-h2:font-black prose-h2:text-[#0f345a] prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:tracking-tight
        prose-p:text-slate-600 prose-p:text-lg prose-p:leading-[1.8] prose-p:mb-8 prose-p:text-justify
        prose-li:text-slate-600 prose-li:text-lg prose-li:mb-4
        prose-strong:text-[#0f345a] prose-strong:font-black
        prose-hr:border-slate-100 prose-hr:my-16
      ">
        <slot />
      </article>

      <!-- Footer CTA -->
      <div class="mt-24 p-12 rounded-[40px] bg-slate-50 border border-slate-100 text-center shadow-inner">
        <h3 class="text-3xl font-sans font-black text-[#0f345a] mb-6 tracking-tight">{t('nav.contact')}</h3>
        <p class="text-slate-500 mb-10 max-w-md mx-auto text-lg leading-relaxed">
          {frontmatter.title} {lang === 'tr' ? 'hizmetimiz hakkında detaylı bilgi ve teklif almak için bizimle iletişime geçin.' : 'solutions, contact us for detailed information and a quote.'}
        </p>
        <a 
          href={`${base}/${lang}/#contact`} 
          class="inline-block px-12 py-5 bg-[#0f345a] text-white rounded-2xl font-sans font-black uppercase tracking-widest hover:bg-blue-600 hover:shadow-xl transition-all duration-300 shadow-lg shadow-blue-900/10"
        >
          {t('nav.contact')}
        </a>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  /* Custom prose styling to match the premium theme */
  .prose-gold :where(h2):not(:where([class~="not-prose"] *)) {
    border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    padding-bottom: 0.5rem;
  }
</style>
