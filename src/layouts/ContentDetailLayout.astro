---
import Layout from './Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  frontmatter: any;
  showContactCTA?: boolean;
  galleryImages?: any[];
  otherProducts?: any[];
  otherServices?: any[];
}

const { frontmatter, showContactCTA = true, galleryImages = [], otherProducts = [], otherServices = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`${frontmatter.title} | Luvi Bilişim`} lang={lang}>
  
  <!-- Progress Bar for long content -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-[#5dade2] z-[101] transition-all duration-300 w-0"></div>

  <main class="pt-14 pb-32 bg-slate-50 min-h-screen">
    <div class="container mx-auto px-4 md:px-8 max-w-6xl">


      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <!-- Sidebar (Hidden on Mobile) -->
        <aside class="hidden lg:flex lg:col-span-3 flex-col gap-12 sticky top-40">
           <div class="flex flex-col gap-6">
              <h4 class="text-[#154360] font-sans font-black text-[11px] tracking-[0.4em] uppercase opacity-40">{lang === 'tr' ? 'BÖLÜMLER' : 'SECTIONS'}</h4>
              <nav id="toc" class="flex flex-col gap-4 border-l-2 border-slate-50 ml-1">
                <!-- TOC items will be injected or hardcoded if needed, but for now just a placeholder for visual style -->
              </nav>
           </div>
        </aside>

        <!-- Main Content Column -->
        <div class="lg:col-span-9">
          <div class="bg-white rounded-[48px] p-8 md:p-16 lg:p-24 shadow-[0_20px_50px_rgba(21,67,96,0.05)] border border-slate-100">
            <!-- Header -->
            <header class="mb-20">
              {frontmatter.pubDate && (
                <span class="inline-block px-4 py-1.5 bg-slate-50 text-[#5dade2] text-[10px] font-black tracking-widest rounded-full mb-8 uppercase">
                  {new Date(frontmatter.pubDate).toLocaleDateString(lang === 'tr' ? 'tr-TR' : 'en-US', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
              )}
              
              {frontmatter.logo ? (
                <!-- Product/Brand page: Logo centered -->
                <div class="flex flex-col items-center text-center gap-8">
                  <div class="flex items-center justify-center py-4 group">
                    <img 
                      src={`${base}${frontmatter.logo}`} 
                      alt={frontmatter.title} 
                      class="h-20 md:h-28 lg:h-32 w-auto object-contain transition-transform duration-700 group-hover:scale-110" 
                    />
                  </div>
                  <div class="h-1.5 w-24 bg-gradient-to-r from-[#5dade2] to-[#154360] rounded-full shadow-[0_4px_10px_rgba(93,173,226,0.3)]"></div>
                  <p class="text-slate-400 text-xl md:text-2xl font-sans leading-relaxed font-light max-w-3xl">
                    {frontmatter.description}
                  </p>
                </div>
              ) : (
                <!-- Service page: Centered Title + Icon for premium consistency -->
                <div class="flex flex-col items-center text-center gap-6">
                  {frontmatter.icon && (
                    <div class="w-20 h-20 rounded-[28px] bg-white shadow-[0_15px_35px_rgba(21,67,96,0.08)] border border-slate-100 flex items-center justify-center group hover:scale-110 transition-all duration-700">
                      <div class="text-[#5dade2] group-hover:text-[#154360] transition-colors duration-500">
                         <div class="w-8 h-8 border-[2.5px] border-current rounded-full flex items-center justify-center">
                            <div class="w-2 h-2 bg-current rounded-full"></div>
                         </div>
                      </div>
                    </div>
                  )}
                  <h1 class="text-3xl md:text-5xl lg:text-6xl font-heading font-black text-[#154360] leading-[1.1] tracking-tighter max-w-4xl">
                    {frontmatter.title}
                  </h1>
                  <div class="h-1.5 w-24 bg-gradient-to-r from-[#5dade2] to-[#154360] rounded-full shadow-[0_4px_10px_rgba(93,173,226,0.3)]"></div>
                  <p class="text-slate-500 text-lg md:text-xl font-sans leading-relaxed font-light max-w-3xl">
                    {frontmatter.description}
                  </p>
                </div>
              )}
            </header>

            <!-- Main Cover Image -->
            {frontmatter.image && (
              <div class="mb-24 rounded-[64px] overflow-hidden bg-slate-50 aspect-video shadow-[0_45px_120px_-25px_rgba(21,67,96,0.18)] border border-slate-100 cursor-zoom-in lightbox-trigger group">
                 <Image 
                   src={frontmatter.image} 
                   alt={frontmatter.title} 
                   class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                 />
              </div>
            )}
            <!-- Content -->
            <!-- Content area with manual styling for premium feel -->
            <article class="content-detail-prose prose-container max-w-none">
              <slot />
            </article>


          </div>

          <!-- Gallery (if any) - Outside the card for better visual flow -->
          {galleryImages.length > 0 && (
            <div class="mt-40">
              <h2 class="text-3xl font-black text-[#154360] mb-16 tracking-tighter flex items-center gap-6">
                 {lang === 'tr' ? 'Görsel Arşivi' : 'Visual Archive'}
                 <div class="h-[2px] flex-1 bg-slate-200"></div>
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {galleryImages.map((img: any) => (
                  <div class="group relative aspect-video rounded-[40px] overflow-hidden bg-slate-50 border border-slate-100 shadow-lg hover:shadow-2xl transition-all duration-700 cursor-zoom-in lightbox-trigger">
                    <Image 
                      src={img} 
                      alt={frontmatter.title} 
                      class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
                    />
                    <div class="absolute inset-0 bg-[#154360]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      <!-- Other Products/Services Quick Links (outside grid to prevent overlap) -->
      {(otherProducts.length > 0 || otherServices.length > 0) && (
        <div class="mt-24">
          <div class="border-t border-slate-200 pt-16">
            <div class="flex items-center gap-6 mb-12">
              <h2 class="text-[#154360] font-heading font-black text-2xl md:text-3xl tracking-tight whitespace-nowrap">
                {otherProducts.length > 0
                  ? (lang === 'tr' ? 'Diğer Çözümlerimiz' : 'Our Other Solutions')
                  : (lang === 'tr' ? 'Diğer Hizmetlerimiz' : 'Our Other Services')}
              </h2>
              <div class="h-[2px] flex-1 bg-slate-200"></div>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-4">
              {(otherProducts.length > 0 ? otherProducts : otherServices).map((item: any) => {
                const itemSlug = item.id.split('/').pop()?.replace('.md', '').replace(/\/(tr|en)$/, '').split('/').shift();
                const section = otherProducts.length > 0 ? 'products' : 'services';
                
                // For services, items might not have a logo, so we use their icons if possible, or just text
                return (
                  <a 
                    href={`${base}/${item.data.lang}/${section}/${itemSlug}`}
                    class="group flex flex-col items-center justify-center p-5 bg-white rounded-2xl border border-slate-100 hover:border-[#5dade2]/30 hover:shadow-lg hover:shadow-[#5dade2]/5 transition-all duration-500 text-center"
                    title={item.data.title}
                  >
                    {item.data.logo ? (
                      <img 
                        src={`${base}${item.data.logo}`} 
                        alt={item.data.title} 
                        class="h-8 md:h-10 w-auto object-contain grayscale group-hover:grayscale-0 opacity-50 group-hover:opacity-100 transition-all duration-500 group-hover:scale-110" 
                      />
                    ) : (
                      <div class="flex flex-col items-center gap-2">
                         <div class="text-[#5dade2] group-hover:text-[#154360] font-black text-[10px] uppercase tracking-widest opacity-40 group-hover:opacity-100 transition-all">
                             {item.data.title.split(' ').slice(0, 2).join(' ')}
                         </div>
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      )}
    </div>
    </div>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-[200] bg-[#0b1a2b]/95 backdrop-blur-3xl hidden items-center justify-center p-4 md:p-12 opacity-0 transition-opacity duration-500 cursor-zoom-out">
      <button id="close-lightbox" class="absolute top-10 right-10 w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white hover:bg-white/10 transition-all z-[201]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
      </button>
      <img id="lightbox-img" src="" alt="Large View" class="max-w-full max-h-full object-contain rounded-3xl shadow-[0_50px_150px_-30px_rgba(0,0,0,0.5)] transform scale-95 transition-transform duration-500 border border-white/5" />
  </div>
</Layout>

<style is:global>
  /* Custom Content Styling - Manual "Prose" replacement for consistent elite corporate look */
  .content-detail-prose {
    --text-primary: #154360;
    --text-body: #475569;
    --accent: #5dade2;
    --h2-spacing: 6rem;
    --h3-spacing: 3rem;
  }

  .content-detail-prose h2 {
    color: var(--text-primary) !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 2.5rem !important;
    font-weight: 900 !important;
    line-height: 1.2 !important;
    margin-top: 5rem !important;
    margin-bottom: 2rem !important;
    letter-spacing: -0.03em !important;
    position: relative;
    padding-left: 2.5rem;
    display: block !important;
  }
  
  @media (max-width: 768px) {
    .content-detail-prose h2 {
      font-size: 1.85rem !important;
      padding-left: 2rem;
      margin-top: 4rem !important;
    }
  }

  .content-detail-prose h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.2em;
    bottom: 0.2em;
    width: 8px;
    background: linear-gradient(to bottom, #5dade2, #154360);
    border-radius: 99px;
    box-shadow: 0 4px 12px rgba(93, 173, 226, 0.3);
  }

  .content-detail-prose h3 {
    color: #1c5d8e !important;
    font-family: 'Montserrat', sans-serif !important;
    font-size: 1.85rem !important;
    font-weight: 800 !important;
    margin-top: 3.5rem !important;
    margin-bottom: 1.25rem !important;
    letter-spacing: -0.02em !important;
    padding-left: 1.5rem;
    border-left: 5px solid #e2e8f0;
    line-height: 1.3 !important;
    display: block !important;
  }

  .content-detail-prose p {
    color: var(--text-body) !important;
    font-size: 1.15rem !important;
    line-height: 1.75 !important;
    margin-bottom: 1.75rem !important;
    text-align: left;
    font-weight: 400;
  }

  /* First paragraph after h2/h3 special treatment */
  .content-detail-prose h2 + p,
  .content-detail-prose h3 + p {
    font-size: 1.25rem !important;
    color: #334155 !important;
    font-weight: 500;
  }

  .content-detail-prose strong {
    color: var(--text-primary);
    font-weight: 800;
  }

  .content-detail-prose ul {
    margin-top: 2rem !important;
    margin-bottom: 3rem !important;
    padding-left: 0.5rem;
  }

  .content-detail-prose ul li {
    position: relative;
    padding-left: 2.5rem;
    list-style: none !important;
    margin-bottom: 1.25rem !important;
    color: var(--text-body) !important;
    font-size: 1.2rem !important;
    line-height: 1.6 !important;
  }

  .content-detail-prose ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.75rem;
    width: 14px;
    height: 4px;
    background-color: var(--accent);
    border-radius: 99px;
  }

  .content-detail-prose blockquote {
    border-left: 8px solid var(--accent);
    padding: 3rem 2rem 3rem 4rem;
    margin: 4rem 0;
    background: #f8fafc;
    border-radius: 0 40px 40px 0;
    font-style: italic;
    font-size: 1.75rem;
    color: var(--text-primary);
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    line-height: 1.4;
    position: relative;
  }
  
  .content-detail-prose blockquote::after {
    content: '"';
    position: absolute;
    top: 1rem;
    left: 1.5rem;
    font-size: 5rem;
    opacity: 0.1;
    color: var(--text-primary);
  }

  /* Restore and style HR */
  .content-detail-prose hr {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, #e2e8f0, transparent);
    margin: 4rem 0 !important;
    display: block !important;
    visibility: visible !important;
  }

  /* List of items that look like checklist */
  .content-detail-prose li > strong:only-child {
    display: block;
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* TOC Active Link Highlight */
  #toc a.active {
    color: var(--accent);
    border-left-color: var(--accent);
    padding-left: 1.5rem;
    font-weight: 800;
    background: linear-gradient(to right, rgba(93, 173, 226, 0.05), transparent);
  }
</style>

<script is:inline>
  // Progress Bar
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById("progress-bar");
    if (bar) bar.style.width = scrolled + "%";
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const triggers = document.querySelectorAll('.lightbox-trigger');
  const closeBtn = document.getElementById('close-lightbox');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const img = trigger.querySelector('img');
      if (img) {
        lightboxImg.src = img.src;
        lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        setTimeout(() => lightbox.classList.add('active'), 10);
      }
    });
  });

  function closeLightbox() {
    lightbox.classList.remove('active');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }, 500);
  }

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox || e.target === lightboxImg) {
      closeLightbox();
    }
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });

  // Simple TOC Generation
  const article = document.querySelector('article');
  const toc = document.getElementById('toc');
  if (article && toc) {
    const headings = article.querySelectorAll('h2');
    headings.forEach((h, index) => {
      const id = `section-${index}`;
      h.setAttribute('id', id);
      const link = document.createElement('a');
      link.href = `#${id}`;
      link.textContent = h.textContent;
      link.className = 'text-slate-400 font-sans text-[11px] font-bold tracking-tight py-2 border-l-2 border-transparent pl-4 hover:text-[#154360] transition-all truncate';
      toc.appendChild(link);
    });
  }
</script>
