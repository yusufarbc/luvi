---
import '../styles/global.css';

interface Props {
	title: string;
	lang: string;
	description?: string;
}

const { title, lang, description = "Yarının olasılıkları, bugünün dijital refleksi" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--font-heading: 'Poppins', sans-serif;
		--font-body: 'Poppins', sans-serif;
	}
	
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-heading);
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	
	body {
		font-family: var(--font-body);
		color: #2c3e50;
	}
</style>
